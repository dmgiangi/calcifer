#!/usr/bin/env bash
# =============================================================================
# Calcifer Deploy CLI - Python Wrapper
# =============================================================================
# LLM-friendly deployment script with JSON output
# Delegates to Python CLI: calcifer-cli/calcifer-cli.py
# =============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_PATH="${SCRIPT_DIR}/calcifer-cli/calcifer-cli.py"

# Check Python is available
if ! command -v python3 &>/dev/null; then
    echo '{"success": false, "errors": [{"message": "Python 3 not found"}]}'
    exit 1
fi

# Execute Python CLI with all arguments
exec python3 "${CLI_PATH}" "$@"

