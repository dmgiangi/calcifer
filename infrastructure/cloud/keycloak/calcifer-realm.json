{
  "realm": "calcifer",
  "enabled": true,
  "displayName": "Calcifer IoT Platform",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${GOOGLE_CLIENT_ID:your-google-client-id}",
        "clientSecret": "${GOOGLE_CLIENT_SECRET:your-google-client-secret}",
        "defaultScope": "openid email profile",
        "syncMode": "INHERIT",
        "useJwksUrl": "true"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "email-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "hardcoded-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "attribute": "emailVerified",
        "attribute.value": "true"
      }
    },
    {
      "name": "username-from-email",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-username-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "template": "${CLAIM.email}"
      }
    },
    {
      "name": "first-name-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "given_name",
        "user.attribute": "firstName"
      }
    },
    {
      "name": "last-name-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "family_name",
        "user.attribute": "lastName"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full access to all services and configurations"
      },
      {
        "name": "operator",
        "description": "Can control devices and view dashboards"
      },
      {
        "name": "viewer",
        "description": "Read-only access to dashboards"
      }
    ]
  },
  "groups": [
    {
      "name": "admins",
      "realmRoles": [
        "admin"
      ]
    },
    {
      "name": "operators",
      "realmRoles": [
        "operator"
      ]
    },
    {
      "name": "viewers",
      "realmRoles": [
        "viewer"
      ]
    }
  ],
  "users": [
    {
      "username": "dem.gianluigi@gmail.com",
      "enabled": true,
      "email": "dem.gianluigi@gmail.com",
      "firstName": "Gianluigi",
      "lastName": "Demartini",
      "emailVerified": true,
      "realmRoles": [
        "admin"
      ],
      "groups": [
        "admins"
      ]
    },
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@calcifer.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": true
        }
      ],
      "realmRoles": [
        "admin"
      ],
      "groups": [
        "admins"
      ]
    },
    {
      "username": "operator",
      "enabled": true,
      "email": "operator@calcifer.local",
      "firstName": "Operator",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "operator",
          "temporary": true
        }
      ],
      "realmRoles": [
        "operator"
      ],
      "groups": [
        "operators"
      ]
    },
    {
      "username": "viewer",
      "enabled": true,
      "email": "viewer@calcifer.local",
      "firstName": "Viewer",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "viewer",
          "temporary": true
        }
      ],
      "realmRoles": [
        "viewer"
      ],
      "groups": [
        "viewers"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "calcifer-gateway",
      "enabled": true,
      "publicClient": false,
      "secret": "change-me-in-production",
      "redirectUris": [
        "https://*.dmgiangi.dev/*",
        "https://auth.dmgiangi.dev/_oauth",
        "http://localhost/*"
      ],
      "webOrigins": [
        "https://*.dmgiangi.dev"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "https://*.dmgiangi.dev/*"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "profile",
    "email",
    "roles"
  ]
}

