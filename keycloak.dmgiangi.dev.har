t\",\"value\":\"You haven't created any roles for this client. Create a role to get started.\"},{\"key\":\"attributeDisplayName\",\"value\":\"Display name\"},{\"key\":\"userProviderSaveSuccess\",\"value\":\"User federation provider successfully saved\"},{\"key\":\"month\",\"value\":\"Month\"},{\"key\":\"multivaluedHelp\",\"value\":\"If this attribute supports multiple values. This setting is an indicator and does not enable any validation\"},{\"key\":\"dropNonexistingGroupsDuringSyncHelp\",\"value\":\"If this flag is true, then during sync of groups from LDAP to Keycloak, we will keep just those Keycloak groups that still exist in LDAP. The rest will be deleted.\"},{\"key\":\"addKerberosWizardTitle\",\"value\":\"Add Kerberos user federation provider\"},{\"key\":\"noPasswordPolicies\",\"value\":\"No password policies\"},{\"key\":\"organizationsEnabledHelp\",\"value\":\"If enabled, allows managing organizations. Otherwise, existing organizations are still kept but you will not be able to manage them anymore or authenticate their members.\"},{\"key\":\"authorizationSignedResponseAlg\",\"value\":\"Authorization response signature algorithm\"},{\"key\":\"title\",\"value\":\"Authentication\"},{\"key\":\"accessTokenLifespan\",\"value\":\"Access Token Lifespan\"},{\"key\":\"retry\",\"value\":\"Press here to refresh and continue\"},{\"key\":\"disableConfirmTitle\",\"value\":\"Disable realm?\"},{\"key\":\"custom\",\"value\":\"Custom Attribute...\"},{\"key\":\"keyTab\",\"value\":\"Key tab\"},{\"key\":\"addSamlProvider\",\"value\":\"Add SAML provider\"},{\"key\":\"permission\",\"value\":\"Permission\"},{\"key\":\"addOrganizationAttributes.help\",\"value\":\"If enabled, the organization attributes will be available for each organization mapped to the token.\"},{\"key\":\"addAttributesGroupTranslationInfo\",\"value\":\"Add translations for this field using the icon next to the \\\"Display name\\\" field.\"},{\"key\":\"tokenLifespan.never\",\"value\":\"Never expires\"},{\"key\":\"