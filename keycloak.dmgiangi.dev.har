oupMembershipError\",\"value\":\"Error removing group membership: {{error}}\"},{\"key\":\"locale_pt\",\"value\":\"Portuguese (Portugu├¬s)\"},{\"key\":\"deleteExecutorSuccess\",\"value\":\"Success! The executor was deleted.\"},{\"key\":\"eventTypes.INTROSPECT_TOKEN_ERROR.name\",\"value\":\"Introspect token error\"},{\"key\":\"usernameHelperText\",\"value\":\"Enter the username of the user for this identity provider.\"},{\"key\":\"includeInAccessToken.tooltip\",\"value\":\"Should the claim be added to the access token?\"},{\"key\":\"clientScopesCondition\",\"value\":\"Expected Scopes\"},{\"key\":\"global\",\"value\":\"Global\"},{\"key\":\"clientUpdaterSourceRoles\",\"value\":\"Updating entity role\"},{\"key\":\"caseSensitiveOriginalUsername\",\"value\":\"Case-sensitive username\"},{\"key\":\"deleteClientPolicyProfileConfirm\",\"value\":\"This action will permanently delete {{profileName}} from the policy {{policyName}}. This cannot be undone.\"},{\"key\":\"deleteExecutorProfileConfirm\",\"value\":\"The action will permanently delete {{executorName}}. This cannot be undone.\"},{\"key\":\"locale_sv\",\"value\":\"Swedish (Svenska)\"},{\"key\":\"eventTypes.CLIENT_INFO_ERROR.name\",\"value\":\"Client info error\"},{\"key\":\"displayDescriptionHintHelp\",\"value\":\"A text that should be used as a tooltip when rendering user-facing forms.\"},{\"key\":\"emptyClientScopesPrimaryAction\",\"value\":\"Add client scopes\"},{\"key\":\"addStepTo\",\"value\":\"Add step to {{name}}\"},{\"key\":\"eventTypes.AUTHREQID_TO_TOKEN_ERROR.description\",\"value\":\"Authreqid to token error\"},{\"key\":\"policiesConfigTypes.jsonEditor\",\"value\":\"JSON editor\"},{\"key\":\"locale_ru\",\"value\":\"Russian (čĆčāčüčüą║ąĖą╣)\"},{\"key\":\"editUsername\",\"value\":\"If enabled, the username field is editable, readonly otherwise.\"},{\"key\":\"noTokensInstructions\",\"value\":\"You haven't created any initial access tokens. Create an initial access token by clicking \\\"Create\\\".\"},{\"key\":\"lo