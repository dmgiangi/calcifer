y\":\"keyPassword\",\"value\":\"Key password\"},{\"key\":\"emptyAddClientScopes\",\"value\":\"No client scopes\"},{\"key\":\"changeTypeTo\",\"value\":\"Change type to\"},{\"key\":\"generateKeys\",\"value\":\"Generate keys?\"},{\"key\":\"savePasswordError\",\"value\":\"Error saving password: {{error}}\"},{\"key\":\"enabledWhenTooltip\",\"value\":\"Specifies when attribute is available. When scopes are used, attribute is available when at least one of configured scopes is applied in the login request. Both default and optional scopes of current request are evaluated. In the admin console and account console contexts, scopes are not evaluated and attribute is always available (if not further restricted by permissions).\"},{\"key\":\"allGroups\",\"value\":\"All groups\"},{\"key\":\"createPolicy\",\"value\":\"Create client policy\"},{\"key\":\"mapperSaveSuccess\",\"value\":\"Mapper saved successfully.\"},{\"key\":\"eventTypes.UPDATE_CONSENT.description\",\"value\":\"Update consent\"},{\"key\":\"userInfoResponseEncryptionContentEncryptionAlgorithmHelp\",\"value\":\"JWA Algorithm used for content encryption in encrypting User Info Endpoint responses. If User Info response encryption key management algorithm is specified, the default for this value is A128CBC-HS256.\"},{\"key\":\"credentialResetEmailError\",\"value\":\"Failed: {{error}}\"},{\"key\":\"referralHelp\",\"value\":\"Specifies if LDAP referrals should be followed or ignored. Please note that enabling referrals can slow down authentication as it allows the LDAP server to decide which other LDAP servers to use. This could potentially include untrusted servers.\"},{\"key\":\"addClientProfileSuccess\",\"value\":\"New client profile added\"},{\"key\":\"selectThemeType\",\"value\":\"Select theme type\"},{\"key\":\"displayOnClient\",\"value\":\"Display client on screen\"},{\"key\":\"parRequestUriLifespanHelp\",\"value\":\"Number that represents the lifetime of the request URI.  The default value is 1 minute.\"},{\"key\":\"ldapAdvancedSettingsDescription\",\"value\":\"This section contains all the other options for more fine-grained configuration of the LDAP storage provider.\"},{\"key\":\"included.custom.audience.label\",\"value\":\"Included Custom Audience\"},{\"key\":\"max-clients.label\",\"value\":\"Max Clients Per Realm\"},{\"key\":\"targetContextAttributesHelp\",\"value\":\"Defines the evaluation of context attributes (claims) instead of identity attributes\"},{\"key\":\"searchForGroups\",\"value\":\"Search group\"},{\"key\":\"requestObject.request only\",\"value\":\"Request only\"},{\"key\":\"eventTypes.UPDATE_EMAIL_ERROR.description\",\"value\":\"Update email error\"},{\"key\":\"emptyPolicies\",\"value\":\"No policies\"},{\"key\":\"manageOrderTableAria\",\"value\":\"List of identity providers in the order listed on the login page\"},{\"key\":\"disableError\",\"value\":\"Could not disable the provider {{error}}\"},{\"key\":\"enableSSL\",\"value\":\"Enable SSL\"},{\"key\":\"advancedSettings\",\"value\":\"Advanced settings\"},{\"key\":\"organizationUsersAddedError\",\"value\":\"Could not add users to the organization: {{error}}\"},{\"key\":\"adminTheme\",\"value\":\"Admin theme\"},{\"key\":\"alias\",\"value\":\"Alias\"},{\"key\":\"eventTypes.SEND_IDENTITY_PROVIDER_LINK_ERROR.name\",\"value\":\"Send identity provider link error\"},{\"key\":\"inputTypePlaceholder\",\"value\":\"Input placeholder\"},{\"key\":\"clearUserEvents\",\"value\":\"Clear user events\"},{\"key\":\"descriptionHelp\",\"value\":\"Help text for the description of the new flow\"},{\"key\":\"permanentLockout\",\"value\":\"Permanent lockout\"},{\"key\":\"debug\",\"value\":\"Debug\"},{\"key\":\"missingUsernameMessage\",\"value\":\"'{{0}}': Please specify username.\"},{\"key\":\"roleMappingUpdatedError\",\"value\":\"Could not update role mapping {{error}}\"},{\"key\":\"importFileHelp\",\"value\":\"File to import a key\"},{\"key\":\"policyDecisionStagey\",\"value\":\"The decision strategy dictates how the policies associated with a given permission are evaluated and how a final decision is obtained. 'Affirmative' means that at least one policy must evaluate to a positive decision in order for the final decision to be also positive. 'Unanimous' means that all policies must evaluate to a positive decision in order for the final decision to be also positive. 'Consensus' means that the number of positive decisions must be greater than the number of negative decisions. If the number of positive and negative is the same, the final decision will be negative.\"},{\"key\":\"addTranslation\",\"value\":\"Add translation\"},{\"key\":\"setAsDefaultAction\",\"value\":\"Set as default action\"},{\"key\":\"noGroupsText\",\"value\":\"You haven't added this user to any groups. Join a group to get started.\"},{\"key\":\"supportedLocalesHelp\",\"value\":\"The locales to support for this realm. The user chooses one of these locales on the login screen.\"},{\"key\":\"resetCredentialsError\",\"value\":\"Error resetting users credentials: {{error}}\"},{\"key\":\"unspecified\",\"value\":\"Unspecified\"},{\"key\":\"active\",\"value\":\"Active\"},{\"key\":\"generateKeysDescription\",\"value\":\"If you generate new keys, you can download the keystore with the private key automatically and save it on your client's side. Keycloak server will save just the certificate and public key, but not the private key.\"},{\"key\":\"addSubFlowTitle\",\"value\":\"Add a sub-flow\"},{\"key\":\"evictionDayHelp\",\"value\":\"Day of the week the entry will become invalid\"},{\"key\":\"permissionResources\",\"value\":\"Specifies that this permission must be applied to a specific resource instance.\"},{\"key\":\"redirectURIHelp\",\"value\":\"The redirect uri to use when configuring the identity provider.\"},{\"key\":\"deniedScopes\",\"value\":\"Denied scopes\"},{\"key\":\"allow-default-scopes.tooltip\",\"value\":\"If on, newly registered clients will be allowed to have client scopes mentioned in realm default client scopes or realm optional client scopes\"},{\"key\":\"requestObjectRequiredHelp\",\"value\":\"Specifies if the client needs to provide a request object with their authorization requests, and what method they can use for this. If set to \\\"not required\\\", providing a request object is optional. In all other cases, providing a request object is mandatory. If set to \\\"request\\\", the request object must be provided by value. If set to \\\"request_uri\\\", the request object must be provided by reference. If set to \\\"request or request_uri\\\", either method can be used.\"},{\"key\":\"removeConfirm_one\",\"value\":\"Are you sure you want to remove this group\"},{\"key\":\"Monday\",\"value\":\"Monday\"},{\"key\":\"resetCredentialsSuccess\",\"value\":\"The password has been reset successfully.\"},{\"key\":\"clientAssertionAudienceHelp\",\"value\":\"The audience to use for the client assertion. The default value is the IDP's token endpoint URL.\"},{\"key\":\"kcNumberFormat\",\"value\":\"Number Format\"},{\"key\":\"attributeGroup\",\"value\":\"Attribute group\"},{\"key\":\"credentialResetConfirmText\",\"value\":\"Are you sure you want to send email to user\"},{\"key\":\"helpFileUpload\",\"value\":\"Upload a JSON file\"},{\"key\":\"fineGrainOpenIdConnectConfiguration\",\"value\":\"Fine grain OpenID Connect configuration\"},{\"key\":\"noTranslations\",\"value\":\"No translations\"},{\"key\":\"count\",\"value\":\"Count\"},{\"key\":\"selectAuthorizationSignedResponseAlgorithm\",\"value\":\"Select authorization signed response algorithm\"},{\"key\":\"transientUser\",\"value\":\"Transient\"},{\"key\":\"groupNameLdapAttributeHelp\",\"value\":\"Name of LDAP attribute, which is used in group objects for name and RDN of group. Usually it will be 'cn'. In this case typical group/role object may have DN like 'cn=Group1,ouu=groups,dc=example,dc=org'.\"},{\"key\":\"deleteError\",\"value\":\"Could not delete the provider {{error}}\"},{\"key\":\"keysCache\",\"value\":\"Keys Cache\"},{\"key\":\"pkceEnabled\",\"value\":\"Use PKCE\"},{\"key\":\"organizationUsersLeft_one\",\"value\":\"User left the organization\"},{\"key\":\"mapperTypeFullNameLdapMapperHelp\",\"value\":\"Used to map the full-name of a user from single attribute in LDAP (usually 'cn' attribute) to firstName and lastName attributes of UserModel in Keycloak DB\"},{\"key\":\"deleteAttributeError\",\"value\":\"Attribute not deleted: {{error}}\"},{\"key\":\"connectionURL\",\"value\":\"Connection URL\"},{\"key\":\"validateCustomUserSearchFilter\",\"value\":\"Filter must be enclosed in parentheses, for example: (filter)\"},{\"key\":\"eventTypes.FEDERATED_IDENTITY_LINK_ERROR.name\",\"value\":\"Federated identity link error\"},{\"key\":\"executorAuthenticatorMultiSelectHelpText\",\"value\":\"Executor Authenticator MultiSelect Help Text\"},{\"key\":\"userAttributeValue\",\"value\":\"User Attribute Value\"},{\"key\":\"notFound\",\"value\":\"Could not find the resource that you are looking for\"},{\"key\":\"eventTypes.LOGIN_ERROR.description\",\"value\":\"Login error\"},{\"key\":\"attestationPreference.direct\",\"value\":\"Direct\"},{\"key\":\"bruteForceStrategyHelp\",\"value\":\"Multiple means wait time will be increased only when number of failures are multiples of '{{failureFactor}}'. Linear means each new failure starting at '{{failureFactor}}' will increase wait time.\"},{\"key\":\"cachePolicyHelp\",\"value\":\"Cache Policy for this storage provider. 'DEFAULT' is whatever the default settings are for the global cache. 'EVICT_DAILY' is a time of day every day that the cache will be invalidated. 'EVICT_WEEKLY' is a day of the week and time the cache will be invalidated. 'MAX_LIFESPAN' is the time in milliseconds that will be the lifespan of a cache entry.\"},{\"key\":\"webAuthnPolicySignatureAlgorithms\",\"value\":\"Signature algorithms\"},{\"key\":\"action\",\"value\":\"Action\"},{\"key\":\"roleAuthentication\",\"value\":\"Role authentication\"},{\"key\":\"authenticatedAccessPoliciesHelp\",\"value\":\"Those Policies are used when Client Registration Service is invoked by authenticated request. This means that the request contains Initial Access Token or Bearer Token.\"},{\"key\":\"realmCache\",\"value\":\"Realm Cache\"},{\"key\":\"reGenerateSigningExplain\",\"value\":\"If you regenerate signing key for client, the Keycloak database will be updated and you may need to download a new adapter for this client.\"},{\"key\":\"enableLdapv3Password\",\"value\":\"Enable the LDAPv3 password modify extended operation\"},{\"key\":\"explainBearerOnly\",\"value\":\"This is a special OIDC type. This client only allows bearer token requests and cannot participate in browser logins.\"},{\"key\":\"validateRdnLdapAttribute\",\"value\":\"You must enter an RDN LDAP attribute\"},{\"key\":\"identityProviderEntityId\",\"value\":\"Identity provider entity ID\"},{\"key\":\"userInfoSignedResponseAlgorithm\",\"value\":\"User info signed response algorithm\"},{\"key\":\"isAccessTokenJWTHelp\",\"value\":\"The Access Token received from the Identity Provider is a JWT and its claims will be accessible for mappers.\"},{\"key\":\"webAuthnUpdateError\",\"value\":\"Could not update webauthn policies due to {{error}}\"},{\"key\":\"paginationHelp\",\"value\":\"Whether the LDAP server supports pagination\"},{\"key\":\"searchItem\",\"value\":\"Search item\"},{\"key\":\"deleteProviderTitle\",\"value\":\"Delete key provider?\"},{\"key\":\"syncLDAPGroupsSuccessful\",\"value\":\"Data successfully synced {{result}}\"},{\"key\":\"clientScopeExplain\",\"value\":\"Client scopes are a common set of protocol mappers and roles that are shared between multiple clients.\"},{\"key\":\"linkAccountTitle\",\"value\":\"Link account to {{provider}}\"},{\"key\":\"invalidateRotatedSuccess\",\"value\":\"Rotated secret successfully removed\"},{\"key\":\"updateSuccessIdentityProvider\",\"value\":\"Provider successfully updated\"},{\"key\":\"supportedApplications\",\"value\":\"Supported applications\"},{\"key\":\"client-attributes.label\",\"value\":\"Client Attributes\"},{\"key\":\"addressClaim.region.label\",\"value\":\"User Attribute Name for Region\"},{\"key\":\"applyToResourceTypeFlagHelp\",\"value\":\"Specifies if this permission should be applied to all resources with a given type. In this case, this permission will be evaluated for all instances of a given resource type.\"},{\"key\":\"deletedErrorIdentityProvider\",\"value\":\"Could not delete the provider {{error}}\"},{\"key\":\"includeInIdToken.label\",\"value\":\"Add to ID token\"},{\"key\":\"steps\",\"value\":\"Steps\"},{\"key\":\"validatorDeletedSuccess\",\"value\":\"Success! User Profile configuration has been saved.\"},{\"key\":\"inheritedFrom\",\"value\":\"Inherited from\"},{\"key\":\"selectRequestObjectEncoding\",\"value\":\"Select request object encoding\"},{\"key\":\"clientSaveError\",\"value\":\"Client could not be updated: {{error}}\"},{\"key\":\"offlineSessionMaxLimitedHelp\",\"value\":\"Enable offline session max\"},{\"key\":\"showInheritedRoles\",\"value\":\"Show inherited roles\"},{\"key\":\"eventTypes.OAUTH2_DEVICE_CODE_TO_TOKEN.description\",\"value\":\"OAuth2 device code to token\"},{\"key\":\"serviceAccount\",\"value\":\"Service accounts roles\"},{\"key\":\"acceptBtn\",\"value\":\"Accept editing button\"},{\"key\":\"selectEvictionHour\",\"value\":\"Select eviction hour\"},{\"key\":\"eventTypes.USER_DISABLED_BY_TEMPORARY_LOCKOUT.description\",\"value\":\"User disabled by temporary lockout\"},{\"key\":\"hmacGenerated\",\"value\":\"hmac-generated\"},{\"key\":\"deleteClientProfileConfirmTitle\",\"value\":\"Delete profile?\"},{\"key\":\"hourHelp\",\"value\":\"Defines the hour when the policy MUST be granted. You can also provide a range by filling the second field. In this case, permission is granted only if current hour is between or equal to the two values you provided.\"},{\"key\":\"generatedAccessToken\",\"value\":\"Generated access token\"},{\"key\":\"attributeConsumingServiceName\",\"value\":\"Attribute Consuming Service Name\"},{\"key\":\"error-invalid-length-too-short\",\"value\":\"'{{0}}' must have minimal length of {{1}}.\"},{\"key\":\"addLdapWizardDescription\",\"value\":\"Text needed here\"},{\"key\":\"backchannelLogoutSessionRequiredHelp\",\"value\":\"Specifying whether a sid (session ID) Claim is included in the Logout Token when the Backchannel Logout URL is used.\"},{\"key\":\"userAttributeHelp\",\"value\":\"Name of user attribute you want to hardcode\"},{\"key\":\"searchForMapper\",\"value\":\"Search for mapper\"},{\"key\":\"confirmClientSecretBody\",\"value\":\"If you regenerate secret, the Keycloak database will be updated and you will need to download a new adapter for this client.\"},{\"key\":\"searchKey\",\"value\":\"Search key\"},{\"key\":\"chooseResources\",\"value\":\"Choose the resources you want to import\"},{\"key\":\"selectOne\",\"value\":\"Select an option\"},{\"key\":\"emailTheme\",\"value\":\"Email theme\"},{\"key\":\"eventTypes.UPDATE_PASSWORD.description\",\"value\":\"Update password\"},{\"key\":\"permissionScopesHelp\",\"value\":\"Specifies that this permission must be applied to one or more scopes.\"},{\"key\":\"moveTo\",\"value\":\"Move to\"},{\"key\":\"emptyEventsInstructions\",\"value\":\"There are no more events types left to add\"},{\"key\":\"emptyBuiltInMappersInstructions\",\"value\":\"All built in mappers were added to this client\"},{\"key\":\"advancedSettingsOpenid-connect\",\"value\":\"This section is used to configure advanced settings of this client related to OpenID Connect protocol\"},{\"key\":\"realmSelector\",\"value\":\"Realm selector\"},{\"key\":\"moveHere\",\"value\":\"Move here\"},{\"key\":\"eventTypes.UNREGISTER_NODE_ERROR.description\",\"value\":\"Unregister node error\"},{\"key\":\"nameIdFormat\",\"value\":\"Name ID format\"},{\"key\":\"deleteClientScope_other\",\"value\":\"Delete {{count}} client scopes\"},{\"key\":\"deleteCredentialsConfirmTitle\",\"value\":\"Delete credentials?\"},{\"key\":\"expires\",\"value\":\"Expires\"},{\"key\":\"syncUsersError\",\"value\":\"Could not sync users: '{{error}}'\"},{\"key\":\"generatedAccessTokenHelp\",\"value\":\"See the example access token, which will be generated and sent to the client when selected user is authenticated. You can see claims and roles that the token will contain based on the effective protocol mappers and role scope mappings and also based on the claims/roles assigned to user himself\"},{\"key\":\"frontchannelLogout\",\"value\":\"Front channel logout\"},{\"key\":\"mapperTypeGroupLdapMapperHelp\",\"value\":\"Used to map group mappings of groups from some LDAP DN to Keycloak group mappings\"},{\"key\":\"sectorIdentifierUri.tooltip\",\"value\":\"Providers that use pairwise sub values and support Dynamic Client Registration SHOULD use the sector_identifier_uri parameter. It provides a way for a group of websites under common administrative control to have consistent pairwise sub values independent of the individual domain names. It also provides a way for Clients to change redirect_uri domains without having to reregister all their users.\"},{\"key\":\"rdnLdapAttribute\",\"value\":\"RDN LDAP attribute\"},{\"key\":\"replyToDisplayName\",\"value\":\"Reply to display name\"},{\"key\":\"noRealmOverridesSearchResultsInstructions\",\"value\":\"Click on the search bar above to search for realm overrides\"},{\"key\":\"xRobotsTag\",\"value\":\"X-Robots-Tag\"},{\"key\":\"tokenDeleteSuccess\",\"value\":\"Initial access token deleted successfully\"},{\"key\":\"contextualInfo\",\"value\":\"Contextual Information\"},{\"key\":\"addAuthnContextDeclRef\",\"value\":\"Add AuthnContext DeclRef\"},{\"key\":\"eventTypes.SEND_IDENTITY_PROVIDER_LINK.description\",\"value\":\"Send identity provider link\"},{\"key\":\"userInfo\",\"value\":\"User info\"},{\"key\":\"addRoles\",\"value\":\"Add roles\"},{\"key\":\"clientPoliciesProfilesHelpText\",\"value\":\"Client Profile allows to setup set of executors, which are enforced for various actions done with the client. Actions can be admin actions like creating or updating client, or user actions like authentication to the client.\"},{\"key\":\"xContentTypeOptions\",\"value\":\"X-Content-Type-Options\"},{\"key\":\"addValidatorRole\",\"value\":\"Add {{validatorName}} validator\"},{\"key\":\"signOutAllActiveSessions\",\"value\":\"Sign out all active sessions\"},{\"key\":\"organizationDeleteConfirm\",\"value\":\"Are you sure you want to permanently delete this organization? If so, all the data of this organization will be deleted.\"},{\"key\":\"useDiscoveryEndpointHelp\",\"value\":\"If this setting is enabled, the discovery endpoint will be used to fetch the provider config. Keycloak can load the config from the endpoint and automatically update the config if the source has any updates\"},{\"key\":\"ownerManagedAccess\",\"value\":\"User-Managed access enabled\"},{\"key\":\"unAssignRole\",\"value\":\"Unassign\"},{\"key\":\"oAuthDevicePollingIntervalHelp\",\"value\":\"The minimum amount of time in seconds that the client should wait between polling requests to the token endpoint.\"},{\"key\":\"selectATheme\",\"value\":\"Select a theme\"},{\"key\":\"permissionsList\",\"value\":\"Permission list\"},{\"key\":\"requirements.DISABLED\",\"value\":\"Disabled\"},{\"key\":\"ldapFullNameAttribute\",\"value\":\"LDAP full name attribute\"},{\"key\":\"testClusterAvailability\",\"value\":\"Test cluster availability\"},{\"key\":\"membershipAttributeType\",\"value\":\"Membership attribute type\"},{\"key\":\"eventTypes.PUSHED_AUTHORIZATION_REQUEST.name\",\"value\":\"Pushed authorization request\"},{\"key\":\"included.client.audience.tooltip\",\"value\":\"The Client ID of the specified audience client will be included in audience (aud) field of the token. If there are existing audiences in the token, the specified value is just added to them. It won't override existing audiences.\"},{\"key\":\"addressClaim.locality.tooltip\",\"value\":\"Name of User Attribute, which will be used to map to 'locality' subclaim inside 'address' token claim. Defaults to 'locality' .\"},{\"key\":\"userProviderSaveError\",\"value\":\"User federation provider could not be saved: {{error}}\"},{\"key\":\"monthHelp\",\"value\":\"Defines the month which the policy MUST be granted. You can also provide a range by filling the second field. In this case, permission is granted only if current month is between or equal to the two values you provided.\"},{\"key\":\"registrationAccessToken\",\"value\":\"Registration access token\"},{\"key\":\"deleteAttributeConfirmTitle\",\"value\":\"Delete attribute?\"},{\"key\":\"importSkipped_zero\",\"value\":\"No records skipped.\"},{\"key\":\"rootURL\",\"value\":\"Root URL appended to relative URLs\"},{\"key\":\"byConfiguration\",\"value\":\"By configuration\"},{\"key\":\"userFedUnlinkUsersConfirmTitle\",\"value\":\"Unlink all users?\"},{\"key\":\"passCurrentLocale\",\"value\":\"Pass current locale\"},{\"key\":\"savePassword\",\"value\":\"Save password\"},{\"key\":\"aesGenerated\",\"value\":\"aes-generated\"},{\"key\":\"executorsTable\",\"value\":\"Executors table\"},{\"key\":\"from\",\"value\":\"From\"},{\"key\":\"greaterThan\",\"value\":\"Must be greater than {{value}}\"},{\"key\":\"anonymousAccessPoliciesHelp\",\"value\":\"Those Policies are used when the Client Registration Service is invoked by unauthenticated request. This means that the request does not contain Initial Access Token nor Bearer Token.\"},{\"key\":\"clientScopeError\",\"value\":\"Could not update scope mapping {{error}}\"},{\"key\":\"createScopeSuccess\",\"value\":\"Authorization scope created successfully\"},{\"key\":\"federationLink\",\"value\":\"Federation link\"},{\"key\":\"smtpFromDisplayPlaceholder\",\"value\":\"Display name for Sender email address\"},{\"key\":\"usermodel.prop.label\",\"value\":\"Property\"},{\"key\":\"invalidPasswordMaxLengthMessage\",\"value\":\"Invalid password: maximum length {0}.\"},{\"key\":\"authenticationOverrides\",\"value\":\"Authentication flow overrides\"},{\"key\":\"artifactResolutionService\",\"value\":\"Artifact Resolution Service\"},{\"key\":\"clientProfilesSubTab\",\"value\":\"Client profiles subtab\"},{\"key\":\"selectEncryptionType\",\"value\":\"Select Encryption type\"},{\"key\":\"value\",\"value\":\"Value\"},{\"key\":\"bruteForceStrategy.MULTIPLE\",\"value\":\"Multiple\"},{\"key\":\"duplicateAGroup\",\"value\":\"Duplicate group\"},{\"key\":\"noRolesInstructions-clientScopes\",\"value\":\"You haven't created any roles for this client scope. Create a role to get started.\"},{\"key\":\"removeImportedUsersMessage\",\"value\":\"Do you really want to remove all imported users? The option \\\"Unlink users\\\" makes sense just for the Edit Mode \\\"Unsynced\\\" and there should be a warning that \\\"unlinked\\\" users without the password in Keycloak database won't be able to authenticate.\"},{\"key\":\"validateUserObjectClasses\",\"value\":\"You must enter one or more user object classes\"},{\"key\":\"encryptionAlgorithm\",\"value\":\"Encryption Algorithm\"},{\"key\":\"requiredForLabel.users\",\"value\":\"Only users\"},{\"key\":\"groupUpdated\",\"value\":\"Group updated\"},{\"key\":\"targetContextAttributes\",\"value\":\"Target Context Attributes\"},{\"key\":\"clientType\",\"value\":\"Client type\"},{\"key\":\"notBeforeSuccess\",\"value\":\"Success! \\\"Not before\\\" set for realm\"},{\"key\":\"clientPoliciesSubTab\",\"value\":\"Client policies subtab\"},{\"key\":\"unanimous\",\"value\":\"Unanimous\"},{\"key\":\"policy-name\",\"value\":\"The name of this policy.\"},{\"key\":\"backchannelLogoutUrlIllegalSchemeError\",\"value\":\"Backchannel logout URL uses an illegal scheme\"},{\"key\":\"clientHelp\",\"value\":\"Select the client making this authorization request. If not provided, authorization requests would be done based on the client you are in.\"},{\"key\":\"metadataDescriptorUrlHelp\",\"value\":\"External URL where Identity Provider publishes the metadata information needed by the client (certificates, keys, other URLs,...).\"},{\"key\":\"realmInfo\",\"value\":\"Realm info\"},{\"key\":\"signOut\",\"value\":\"Sign out\"},{\"key\":\"preserveGroupInheritanceHelp\",\"value\":\"Flag whether group inheritance from LDAP should be propagated to Keycloak. If false, then all LDAP groups will be mapped as flat top-level groups in Keycloak. Otherwise group inheritance is preserved into Keycloak, but the group sync might fail if LDAP structure contains recursions or multiple parent groups per child groups.\"},{\"key\":\"createScopeBasedPermission\",\"value\":\"Create scope-based permission\"},{\"key\":\"logoutAllSessionsError\",\"value\":\"Error! Failed to log out of all sessions: {{error}}.\"},{\"key\":\"partialExport\",\"value\":\"Partial export\"},{\"key\":\"generatedIdToken\",\"value\":\"Generated ID token\"},{\"key\":\"groupDeleteError\",\"value\":\"Error deleting group {{error}}\"},{\"key\":\"updateFirstLoginHelp\",\"value\":\"Update profile on first login\"},{\"key\":\"close\",\"value\":\"Close\"},{\"key\":\"usersDNHelp\",\"value\":\"Full DN of LDAP tree where your users are. This DN is the parent of LDAP users. It could be for example 'ou=users,dc=example,dc=com' assuming that your typical user will have DN like 'uid='john',ou=users,dc=example,dc=com'.\"},{\"key\":\"whoCanView\",\"value\":\"Who can view?\"},{\"key\":\"adminEventsSettings\",\"value\":\"Admin events settings\"},{\"key\":\"passMaxAgeHelp\",\"value\":\"Pass max_age to identity provider.\"},{\"key\":\"noRoles-users\",\"value\":\"No roles for this user\"},{\"key\":\"targetHelp\",\"value\":\"Destination field for the mapper. LOCAL (default) means that the changes are applied to the username stored in local database upon user import. BROKER_ID and BROKER_USERNAME means that the changes are stored into the ID or username used for federation user lookup, respectively.\"},{\"key\":\"forgotPasswordHelpText\",\"value\":\"Show a link on login page for user to click when they have forgotten their credentials.\"},{\"key\":\"itemDeleteConfirm\",\"value\":\"Are you sure you want to permanently delete the item\"},{\"key\":\"organizationName\",\"value\":\"Organization name\"},{\"key\":\"port\",\"value\":\"Port\"},{\"key\":\"addRequestUri\",\"value\":\"Add valid request URIs\"},{\"key\":\"error-invalid-number\",\"value\":\"'{{0}}' is invalid number.\"},{\"key\":\"choose\",\"value\":\"Choose...\"},{\"key\":\"skipped\",\"value\":\"Skipped\"},{\"key\":\"loginTheme\",\"value\":\"Login theme\"},{\"key\":\"includeRepresentationHelp\",\"value\":\"Include JSON representation for create and update requests.\"},{\"key\":\"removeAttribute\",\"value\":\"Remove attribute\"},{\"key\":\"selectOrTypeAKey\",\"value\":\"Select or type a key\"},{\"key\":\"authorizationScopes\",\"value\":\"Authorization scopes\"},{\"key\":\"identityProviderEntityIdHelp\",\"value\":\"The Entity ID used to validate the Issuer for received SAML assertions. If empty, no Issuer validation is performed.\"},{\"key\":\"fromDisplayNameHelp\",\"value\":\"A user-friendly name for the 'From' address (optional).\"},{\"key\":\"eventTypes.EXECUTE_ACTION_TOKEN_ERROR.name\",\"value\":\"Execute action token error\"},{\"key\":\"eventTypes.IDENTITY_PROVIDER_LOGIN.name\",\"value\":\"Identity provider login\"},{\"key\":\"clientOfflineSessionIdleHelp\",\"value\":\"Time a client offline session is allowed to be idle before it expires. Offline tokens are invalidated when a client offline session is expired. The option does not affect the global user SSO session. If not set, it uses the realm Offline Session Idle value.\"},{\"key\":\"itemDeleteConfirmTitle\",\"value\":\"Delete item?\"},{\"key\":\"newClientProfile\",\"value\":\"Create client profile\"},{\"key\":\"otpType\",\"value\":\"OTP type\"},{\"key\":\"artifactBindingResponse\",\"value\":\"ARTIFACT binding response\"},{\"key\":\"grantedScopes\",\"value\":\"Granted scopes\"},{\"key\":\"eventType\",\"value\":\"Event saved type\"},{\"key\":\"useRefreshTokenForClientCredentialsGrant\",