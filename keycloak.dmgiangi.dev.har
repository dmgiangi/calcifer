alue\":\"JWA Algorithm used for key management in encrypting User Info Endpoint responses. This option is needed if you want encrypted User Info Endpoint responses. If left empty, User Info Endpoint responses are not encrypted.\"},{\"key\":\"authnContextDeclRefsHelp\",\"value\":\"Ordered list of requested AuthnContext DeclRefs.\"},{\"key\":\"unlock\",\"value\":\"Unlock\"},{\"key\":\"expireTime\",\"value\":\"Expire time\"},{\"key\":\"requestObject.request or request_uri\",\"value\":\"Request or Request URI\"},{\"key\":\"policyProvider.user\",\"value\":\"Define conditions for your permissions where a set of one or more users is permitted to access an object.\"},{\"key\":\"hideOnLoginPageHelp\",\"value\":\"If hidden, login with this provider is possible only if requested explicitly, for example using the 'kc_idp_hint' parameter.\"},{\"key\":\"orderChangeError\",\"value\":\"Could not change display order of identity providers {{error}}\"},{\"key\":\"addAttributeTranslationInfo\",\"value\":\"Add translations for this field using the icon next to the \\\"Display name\\\" field.\"},{\"key\":\"errorSavingTranslations\",\"value\":\"Error saving translations: '{{error}}'\"},{\"key\":\"secretExpiresOn\",\"value\":\"Secret expires on {{time}}\"},{\"key\":\"idpType.social\",\"value\":\"Social login\"},{\"key\":\"fineGrainSamlEndpointConfig\",\"value\":\"Fine Grain SAML Endpoint Configuration\"},{\"key\":\"eventTypes.RESET_PASSWORD_ERROR.name\",\"value\":\"Reset password error\"},{\"key\":\"yes\",\"value\":\"Yes\"},{\"key\":\"renameGroup\",\"value\":\"Rename group\"},{\"key\":\"kerberosIntegration\",\"value\":\"Kerberos integration\"},{\"key\":\"dedicatedScopes\",\"value\":\"Dedicated scopes\"},{\"key\":\"time\",\"value\":\"Time\"},{\"key\":\"credentialResetEmailSuccess\",\"value\":\"Email sent to user.\"},{\"key\":\"sslType.all\",\"value\":\"All requests\"},{\"key\":\"lastUpdated\",\"value\":\"Last updated\"},{\"key\":\"exportWarningDescription\",\"value\":\"If there is a great 