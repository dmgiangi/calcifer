          "content": {
            "size": 3113,
            "mimeType": "text/html",
            "text": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <base href=\"/resources/ogb7k/admin/keycloak.v2/\">\n    <link rel=\"icon\" type=\"image/svg+xml\" href=\"/resources/ogb7k/admin/keycloak.v2/favicon.svg\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <meta name=\"description\" content=\"The Keycloak Administration Console is a web-based interface for managing Keycloak.\">\n    <title>Keycloak Administration Console</title>\n    <style>\n      body {\n        margin: 0;\n      }\n\n      body, #app {\n        height: 100%;\n      }\n\n      .container {\n        padding: 0;\n        margin: 0;\n        width: 100%;\n      }\n\n      .keycloak__loading-container {\n        height: 100vh;\n        width: 100%;\n        color: #151515;\n        background-color: #fff;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        flex-direction: column;\n        margin: 0;\n      }\n\n      @media (prefers-color-scheme: dark) {\n        .keycloak__loading-container {\n          color: #e0e0e0;\n          background-color: #1b1d21;\n        }\n      }\n\n      #loading-text {\n        z-index: 1000;\n        font-size: 20px;\n        font-weight: 600;\n        padding-top: 32px;\n      }\n    </style>\n    <script type=\"importmap\">\n      {\n        \"imports\": {\n          \"react\": \"/resources/ogb7k/common/keycloak/vendor/react/react.production.min.js\",\n          \"react/jsx-runtime\": \"/resources/ogb7k/common/keycloak/vendor/react/react-jsx-runtime.production.min.js\",\n          \"react-dom\": \"/resources/ogb7k/common/keycloak/vendor/react-dom/react-dom.production.min.js\"\n        }\n      }\n    </script>\n        <link rel=\"stylesheet\" href=\"/resources/ogb7k/admin/keycloak.v2/assets/main-CvkXqs02.css\">\n      <script type=\"module\" src=\"/resources/ogb7k/admin/keycloak.v2/assets/main-CFePQ27m.js\"></script>\n  </head>\n  <body>\n    <div id=\"app\">\n      <main class=\"container\">\n        <div class=\"keycloak__loading-container\">\n          <span class=\"pf-c-spinner pf-m-xl\" role=\"progressbar\" aria-valuetext=\"Loading&hellip;\">\n            <span class=\"pf-c-spinner__clipper\"></span>\n            <span class=\"pf-c-spinner__lead-ball\"></span>\n            <span class=\"pf-c-spinner__tail-ball\"></span>\n          </span>\n          <div>\n            <p id=\"loading-text\">Loading the Administration Console</p>\n          </div>\n        </div>\n      </main>\n    </div>\n    <noscript>JavaScript is required to use the Administration Console.</noscript>\n    <script id=\"environment\" type=\"application/json\">\n      {\n        \"serverBaseUrl\": \"https://keycloak.dmgiangi.dev\",\n        \"adminBaseUrl\": \"https://keycloak.dmgiangi.dev\",\n        \"authUrl\": \"https://keycloak.dmgiangi.dev\",\n        \"authServerUrl\": \"https://keycloak.dmgiangi.dev\",\n        \"realm\": \"master\",\n        \"clientId\": \"security-admin-console\",\n        \"resourceUrl\": \"/resources/ogb7k/admin/keycloak.v2\",\n        \"logo\": \"\",\n        \"logoUrl\": \"\",\n        \"consoleBaseUrl\": \"/admin/master/console/\",\n        \"masterRealm\": \"master\",\n        \"resourceVersion\": \"ogb7k\"\n      }\n    </script>\n  </body>\n</html>\n"
