"rsa\",\"value\":\"rsa\"},{\"key\":\"setPasswordConfirmText\",\"value\":\"Are you sure you want to set the password for the user {{username}}?\"},{\"key\":\"usermodel.clientRoleMapping.clientId.tooltip\",\"value\":\"Client ID for role mappings. Just client roles of this client will be added to the token. If this is unset, client roles of all clients will be added to the token.\"},{\"key\":\"targetOptions.local\",\"value\":\"LOCAL\"},{\"key\":\"userAddedOrganizationError\",\"value\":\"Could not add organizations to the user: {{error}}\"},{\"key\":\"pkceMethodHelp\",\"value\":\"PKCE Method to use\"},{\"key\":\"nameIdPolicyFormat\",\"value\":\"NameID policy format\"},{\"key\":\"deleteConfirmExecution\",\"value\":\"Delete execution?\"},{\"key\":\"scopePermissions.roles.map-role-composite-description\",\"value\":\"Policies that decide if an administrator can apply this role as a composite to another role\"},{\"key\":\"residentKey.Yes\",\"value\":\"Yes\"},{\"key\":\"deleteAttributeText\",\"value\":\"Delete an attribute\"},{\"key\":\"deleteNodeSuccess\",\"value\":\"Node successfully removed\"},{\"key\":\"includeInIntrospection.label\",\"value\":\"Add to token introspection\"},{\"key\":\"executionConfig\",\"value\":\"{{name}} config\"},{\"key\":\"keyError\",\"value\":\"A key must be provided.\"},{\"key\":\"userVerify.preferred\",\"value\":\"Preferred\"},{\"key\":\"roleDetails\",\"value\":\"Role details\"},{\"key\":\"results\",\"value\":\"Results\"},{\"key\":\"addProvider\",\"value\":\"Add provider\"},{\"key\":\"ldapErrorCantWriteOnlyAndReadOnly\",\"value\":\"Can not set write-only and read-only together\"},{\"key\":\"name\",\"value\":\"Name\"},{\"key\":\"clientList\",\"value\":\"Clients\"},{\"key\":\"pagination\",\"value\":\"Pagination\"},{\"key\":\"searchUserEventsBtn\",\"value\":\"Search events\"},{\"key\":\"addressClaim.postal_code.tooltip\",\"value\":\"Name of User Attribute, which will be used to map to 'postal_code' subclaim inside 'address' token claim. Defaults to '