\"deleteScopeWarning\",\"value\":\"The permissions below will be removed when they are no longer used by other authorization scopes:\"},{\"key\":\"addNode\",\"value\":\"Add node\"},{\"key\":\"jwksUrl\",\"value\":\"JWKS URL\"},{\"key\":\"missingEmailMessage\",\"value\":\"'{{0}}': Please specify email.\"},{\"key\":\"eventTypes.IDENTITY_PROVIDER_LOGIN_ERROR.name\",\"value\":\"Identity provider login error\"},{\"key\":\"usersLeftError\",\"value\":\"Could not remove users from the group: {{error}}\"},{\"key\":\"addTypes\",\"value\":\"Add types\"},{\"key\":\"minute\",\"value\":\"Minute\"},{\"key\":\"unsigned\",\"value\":\"Unsigned\"},{\"key\":\"webAuthnPolicyAcceptableAaguids\",\"value\":\"Acceptable AAGUIDs\"},{\"key\":\"noRoles-roles\",\"value\":\"No roles in this realm\"},{\"key\":\"translationDeleteConfirmDialog\",\"value\":\"Are you sure you want to permanently delete {{count}} selected translation(s)?\"},{\"key\":\"deleteMapperConfirm\",\"value\":\"Are you sure you want to permanently delete the mapper {{mapper}}?\"},{\"key\":\"ldapErrorInvalidCustomFilter\",\"value\":\"Custom configured LDAP filter does not start with \\\"(\\\" or does not end with \\\")\\\".\"},{\"key\":\"addressClaim.formatted.tooltip\",\"value\":\"Name of User Attribute, which will be used to map to 'formatted' subclaim inside 'address' token claim. Defaults to 'formatted' .\"},{\"key\":\"predefinedMappingDescription\",\"value\":\"Choose any of the predefined mappings from this table\"},{\"key\":\"reqAuthnConstraints\",\"value\":\"Requested AuthnContext Constraints\"},{\"key\":\"selectIdTokenEncryptionKeyManagementAlgorithm\",\"value\":\"Select Id token encryption key management algorithm\"},{\"key\":\"eventTypes.RESTART_AUTHENTICATION.name\",\"value\":\"Restart authentication\"},{\"key\":\"scopePermissions.clients.view-description\",\"value\":\"Policies that decide if an administrator can view this client\"},{\"key\":\"updateErrorIdentityProvider\",\"value\":\"Could not update the provider {{error}}\"},{\"key\":\"roleRemoveAssociatedText\",\"value\":\"This action will remove {{role}} from {{roleName}}. All the associated roles of {{role}} will also be removed.\"},{\"key\":\"error-number-out-of-range\",\"value\":\"'{{0}}' must be a number between {{1}} and {{2}}.\"},{\"key\":\"ssoSessionIdleRememberMe\",\"value\":\"Time a remember me session is allowed to be idle before it expires. Tokens and browser sessions are invalidated when a session is expired. If not set it uses the standard SSO Session Idle value.\"},{\"key\":\"tokenUrl\",\"value\":\"Token URL\"},{\"key\":\"helpToggleInfo\",\"value\":\"This toggle will enable / disable part of the help info in the UI. Includes any help text, links and popovers.\"},{\"key\":\"updateClientPoliciesError\",\"value\":\"Could not update client policies: {{error}}\"},{\"key\":\"eventTypes.USER_INFO_REQUEST.name\",\"value\":\"User info request\"},{\"key\":\"reloadKeys\",\"value\":\"Reload keys\"},{\"key\":\"clientScopeType.none\",\"value\":\"None\"},{\"key\":\"selectScope\",\"value\":\"Select a scope\"},{\"key\":\"readOnlyHelp\",\"value\":\"Read-only attribute is imported from LDAP to UserModel, but it's not saved back to LDAP when user is updated in Keycloak.\"},{\"key\":\"resourceDeletedError\",\"value\":\"Could not remove the resource {{error}}\"},{\"key\":\"backchannelLogoutUrl\",\"value\":\"Backchannel logout URL\"},{\"key\":\"clientAccesstype\",\"value\":\"Client Access Type\"},{\"key\":\"disabledHelp\",\"value\":\"A disabled user cannot log in.\"},{\"key\":\"eventTypes.UPDATE_PROFILE_ERROR.name\",\"value\":\"Update profile error\"},{\"key\":\"adminThemeHelp\",\"value\":\"Select a theme for administration console.\"},{\"key\":\"eventTypes.REMOVE_CREDENTIAL.description\",\"value\":\"Remove credential\"},{\"key\":\"targetOptions.brokerUsername\",\"value\":\"BROKER_USERNAME\"},{\"key\":\"infoDisabledFeatures\",\"value\":\"Shows all disabled features.\"},{\"key\":\"userSession.modelNote.label\",\"value\":\"User Session Note\"},{\"key\":\"userLabel\",\"value\":\"User label\"},{\"key\":\"otpHashAlgorithm\",\"value\":\"OTP hash algorithm\"},{\"key\":\"importFail\",\"value\":\"Import failed: {{error}}\"},{\"key\":\"show\",\"value\":\"Show\"},{\"key\":\"description\",\"value\":\"Description\"},{\"key\":\"providerId\",\"value\":\"Provider ID\"},{\"key\":\"listExplain\",\"value\":\"Identity providers are social networks or identity brokers that allow users to authenticate to Keycloak.\"},{\"key\":\"tableView\",\"value\":\"Table view\"},{\"key\":\"maxFailureWaitSeconds\",\"value\":\"Max wait\"},{\"key\":\"confirmAccessTokenTitle\",\"value\":\"Regenerate registration access token?\"},{\"key\":\"addDomain\",\"value\":\"Add domain\"},{\"key\":\"protocolMapper\",\"value\":\"Protocol...\"},{\"key\":\"maxTemporaryLockoutsHelp\",\"value\":\"The number of temporary lockouts permitted before the user is permanently locked out.\"},{\"key\":\"eventTypes.IDENTITY_PROVIDER_POST_LOGIN.name\",\"value\":\"Identity provider post login\"},{\"key\":\"ldapGeneralOptionsSettingsDescription\",\"value\":\"This section contains a few basic options common to all user storage providers.\"},{\"key\":\"importSkipped_one\",\"value\":\"One record skipped.\"},{\"key\":\"idTokenSignatureAlgorithmHelp\",\"value\":\"JWA algorithm used for signing ID tokens.\"},{\"key\":\"saveEvents\",\"value\":\"Save events\"},{\"key\":\"testClusterSuccess\",\"value\":\"Successfully verified availability for: {{successNodes}}\"},{\"key\":\"whoWillAppearLinkTextRoles\",\"value\":\"Who will appear in this user list?\"},{\"key\":\"targetClaim\",\"value\":\"Target claim\"},{\"key\":\"assignRole\",\"value\":\"Assign role\"},{\"key\":\"selectIfResourceExists\",\"value\":\"If a resource already exists, specify what should be done\"},{\"key\":\"addExecutor\",\"value\":\"Add executor\"},{\"key\":\"credentialReset\",\"value\":\"Credentials Reset\"},{\"key\":\"eventTypes.CUSTOM_REQUIRED_ACTION_ERROR.name\",\"value\":\"Custom required action error\"},{\"key\":\"reset\",\"value\":\"Reset\"},{\"key\":\"duplicateEmailsHelpText\",\"value\":\"Allow multiple users to have the same email address. Changing this setting will also clear the user's cache. It is recommended to manually update email constraints of existing users in the database after switching off support for duplicate email addresses.\"},{\"key\":\"eventTypes.GRANT_CONSENT.name\",\"value\":\"Grant consent\"},{\"key\":\"userSessionAttribute\",\"value\":\"User Session Attribute\"},{\"key\":\"deleteAllTranslationsSuccess\",\"value\":\"Successfully removed translation(s).\"},{\"key\":\"passwordPoliciesHelp.maxLength\",\"value\":\"The maximum number of characters allowed in the password.\"},{\"key\":\"noSessionsForUser\",\"value\":\"There are currently no active sessions for this user.\"},{\"key\":\"user-events-cleared-error\",\"value\":\"Could not clear the user events {{error}}\"},{\"key\":\"executorType\",\"value\":\"Executor type\"},{\"key\":\"keystorePassword\",\"value\":\"Keystore password\"},{\"key\":\"mapperTypeHardcodedLdapRoleMapperHelp\",\"value\":\"Users imported from LDAP will be automatically added into this configured role.\"},{\"key\":\"mappersList\",\"value\":\"Mappers list\"},{\"key\":\"rootUrl\",\"value\":\"Root URL\"},{\"key\":\"samlSignatureKeyName\",\"value\":\"SAML signature key name\"},{\"key\":\"eventTypes.RESET_PASSWORD_ERROR.description\",\"value\":\"Reset password error\"},{\"key\":\"addUser\",\"value\":\"Add user\"},{\"key\":\"includeAuthnStatementHelp\",\"value\":\"Should a statement specifying the method and timestamp be included in login responses?\"},{\"key\":\"manageAccount\",\"value\":\"Manage account\"},{\"key\":\"policyProvider.group\",\"value\":\"Define conditions for your permissions where a set of one or more groups (and their hierarchies) is permitted to access an object.\"},{\"key\":\"eventTypes.USER_DISABLED_BY_PERMANENT_LOCKOUT_ERROR.description\",\"value\":\"User disabled by permanent lockout error\"},{\"key\":\"emptyPermissions\",\"value\":\"No permissions\"},{\"key\":\"valuePlaceholder\",\"value\":\"Type a value\"},{\"key\":\"usersLeft_other\",\"value\":\"{{count}} users left the group\"},{\"key\":\"pairwiseMalformedClientRedirectURI\",\"value\":\"Client contained an invalid redirect URI.\"},{\"key\":\"updateClientContext\",\"value\":\"Update Client Context\"},{\"key\":\"name-id-format\",\"value\":\"Name ID Format\"},{\"key\":\"noRoles-clientScopes\",\"value\":\"No roles for this client scope\"},{\"key\":\"roleImportError\",\"value\":\"Could not import role\"},{\"key\":\"alwaysReadValueFromLdapHelp\",\"value\":\"If on, then during reading of the LDAP attribute value will always used instead of the value from Keycloak DB.\"},{\"key\":\"usermodel.clientRoleMapping.tokenClaimName.tooltip\",\"value\":\"Name of the claim to insert into the token. This can be a fully qualified name like 'address.street'. In this case, a nested json object will be created. To prevent nesting and use dot literally, escape the dot with backslash (\\\\.). The special token ${client_id} can be used and this will be replaced by the actual client ID. Example usage is 'resource_access.${client_id}.roles'. This is useful especially when you are adding roles from all the clients (Hence 'Client ID' switch is unset) and you want client roles of each client stored separately.\"},{\"key\":\"xFrameOptionsHelp\",\"value\":\"Default value prevents pages from being included by non-origin iframes <1>Learn more</1>\"},{\"key\":\"userNotSaved\",\"value\":\"The user has not been saved: {{error}}\"},{\"key\":\"selectEvictionDay\",\"value\":\"Select eviction day\"},{\"key\":\"cibaExpiresInHelp\",\"value\":\"The expiration time of the \\\"auth_req_id\\\" in seconds since the authentication request was received.\"},{\"key\":\"selectAuthorizationEncryptedResponseEnc\",\"value\":\"Select authorization encrypted response enc\"},{\"key\":\"addOrganizationId.label\",\"value\":\"Add organization id\"},{\"key\":\"rootURLHelp\",\"value\":\"Root URL appended to relative URLs\"},{\"key\":\"searchForRole\",\"value\":\"Search role\"},{\"key\":\"validatorColNames.colConfig\",\"value\":\"Config\"},{\"key\":\"inputTypeRows\",\"value\":\"Input rows\"},{\"key\":\"save-user-eventsHelp\",\"value\":\"If enabled, user events are saved to the database, which makes events available to the admin and account management UIs.\"},{\"key\":\"disableConfirmUser\",\"value\":\"Are you sure you want to disable this user?\"},{\"key\":\"roleExplain\",\"value\":\"Realm roles are the roles that you define for use in the current realm.\"},{\"key\":\"transient\",\"value\":\"Transient\"},{\"key\":\"requestObjectSignatureAlgorithmHelp\",\"value\":\"JWA algorithm, which client needs to use when sending OIDC request object specified by 'request' or 'request_uri' parameters. If set to 'any', Request object can be signed by any algorithm (including 'none' ).\"},{\"key\":\"ldapKerberosSettingsDescription\",\"value\":\"This section contains options useful for the Kerberos integration. This is used only when the LDAP server is used together with Kerberos/SPNEGO for user authentication.\"},{\"key\":\"deleteEvents\",\"value\":\"Clear events\"},{\"key\":\"mapperTypeHardcodedAttributeMapperHelp\",\"value\":\"This mapper will hardcode any model user attribute and some property (like emailVerified or enabled) when importing user from LDAP.\"},{\"key\":\"scopeTypeHelp\",\"value\":\"Client scopes, which will be added as default scopes to each created client\"},{\"key\":\"unmanagedAttributePolicy.ENABLED\",\"value\":\"Enabled\"},{\"key\":\"editTranslationValue\",\"value\":\"Edit translation value\"},{\"key\":\"loa-max-age.tooltip\",\"value\":\"Maximum age in seconds for this level of authentication to be valid. If the particular level is requested and user already authenticated with this level earlier than specified amount of seconds ago, he will not be asked to re-authenticate. But if he authenticated later than specified amount of seconds ago, he will need to re-authenticate with this level again. Value 0 in the configuration means that user is always required to re-authenticate with this level whenever this level is requested.\"},{\"key\":\"requestObjectRequired\",\"value\":\"Request object required\"},{\"key\":\"prompts.none\",\"value\":\"None\"},{\"key\":\"resourcesHelp\",\"value\":\"Specifies that this permission must be applied to a specific resource instance.\"},{\"key\":\"aggregate.attrs.tooltip\",\"value\":\"Indicates if attribute values should be aggregated with the group attributes. If using OpenID Connect mapper the multivalued option needs to be enabled too in order to get all the values. Duplicated values are discarded and the order of values is not guaranteed with this option.\"},{\"key\":\"protocolTypes.oid4vc\",\"value\":\"OpenID for Verifiable Credentials\"},{\"key\":\"noMappers\",\"value\":\"No Mappers\"},{\"key\":\"couldNotLinkIdP\",\"value\":\"Could not link identity provider {{error}}\"},{\"key\":\"samlEntityDescriptorHelp\",\"value\":\"Allows you to load external IDP metadata from a config file or to download it from a URL.\"},{\"key\":\"eventTypes.SEND_VERIFY_EMAIL.name\",\"value\":\"Send verify email\"},{\"key\":\"eventTypes.REGISTER_NODE.name\",\"value\":\"Register node\"},{\"key\":\"userModelAttributeName\",\"value\":\"User model attribute name\"},{\"key\":\"dynamicScope\",\"value\":\"Dynamic scope\"},{\"key\":\"includeInIntrospection.tooltip\",\"value\":\"Should the claim be added to the token introspection?\"},{\"key\":\"logoutServiceArtifactBindingUrlHelp\",\"value\":\"SAML ARTIFACT Binding URL for the client's single logout service. You can leave this blank if you are using a different binding.\"},{\"key\":\"logoutServicePostBindingURL\",\"value\":\"Logout Service POST Binding URL\"},{\"key\":\"assertionConsumerServicePostBindingURLHelp\",\"value\":\"SAML POST Binding URL for the client's assertion consumer service (login responses). You can leave this blank if you do not have a URL for this binding.\"},{\"key\":\"createAuthorizationScope\",\"value\":\"Create authorization scope\"},{\"key\":\"filterByMembershipType\",\"value\":\"Filter by Membership Type\"},{\"key\":\"roleNameLdapAttributeHelp\",\"value\":\"Name of LDAP attribute, which is used in role objects for name and RDN of role. Usually it will be 'cn'. In this case typical group/role object may have DN like 'cn=role1,ou=finance,dc=example,dc=org'.\"},{\"key\":\"regexPattern\",\"value\":\"Regex pattern\"},{\"key\":\"validateSignatureHelp\",\"value\":\"Enable/disable signature validation of external IDP signatures.\"},{\"key\":\"searchForFlow\",\"value\":\"Search for flow\"},{\"key\":\"addAuthnContextClassRef\",\"value\":\"Add AuthnContext ClassRef\"},{\"key\":\"searchForEffectiveMessageBundles\",\"value\":\"Search for message bundle\"},{\"key\":\"client\",\"value\":\"Client\"},{\"key\":\"setToNow\",\"value\":\"Set to now\"},{\"key\":\"associatedRolesRemoved\",\"value\":\"Associated roles have been removed\"},{\"key\":\"whoWillAppearLinkTextUsers\",\"value\":\"Who will appear in this group list?\"},{\"key\":\"optimizeLookup\",\"value\":\"Optimize REDIRECT signing key lookup\"},{\"key\":\"executors\",\"value\":\"Executors\"},{\"key\":\"eventTypes.CLIENT_UPDATE_ERROR.name\",\"value\":\"Client update error\"},{\"key\":\"realm\",\"value\":\"Realm\"},{\"key\":\"prompt\",\"value\":\"Prompt\"},{\"key\":\"signature-algorithm\",\"value\":\"JWA algorithm, which the client needs to use when signing a JWT for authentication. If left blank, the client is allowed to use any appropriate algorithm for the particular client authenticator.\"},{\"key\":\"nameField\",\"value\":\"Name\"},{\"key\":\"transientUserTooltip\",\"value\":\"This user not stored in Keycloak database. It is constructed solely from data provided by the originating identity provider.\"},{\"key\":\"dayMonthHelp\",\"value\":\"Defines the day of month when the policy MUST be granted. You can also provide a range by filling the second field. In this case, permission is granted only if current day of month is between or equal to the two values you provided.\"},{\"key\":\"fullNameLdapWriteOnlyHelp\",\"value\":\"For Write-only, data is propagated to LDAP when a user is created or updated in Keycloak. But this mapper is not used to propagate data from LDAP back into Keycloak. This setting is useful if you configured separate firstName and lastName attribute mappers and you want to use those to read the attribute from LDAP into Keycloak.\"},{\"key\":\"userFedDeleteError\",\"value\":\"Could not delete user federation provider: '{{error}}'\"},{\"key\":\"join\",\"value\":\"Join\"},{\"key\":\"clientUpdaterSourceGroupsHelp\",\"value\":\"The condition checks the group of the entity who tries to create/update the client to determine whether the policy is applied.\"},{\"key\":\"idTokenEncryptionContentEncryptionAlgorithmHelp\",\"value\":\"JWA Algorithm used for content encryption in encrypting ID tokens. This option is needed just if you want encrypted ID tokens. If left empty, ID Tokens are just signed, but not encrypted.\"},{\"key\":\"scopesHelp\",\"value\":\"The scopes to be sent when asking for authorization. It can be a space-separated list of scopes. Defaults to 'openid'.\"},{\"key\":\"clientScopeList\",\"value\":\"Client scopes\"},{\"key\":\"noValidMetaDataFound\",\"value\":\"No valid metadata was found at this URL: '{{error}}'\"},{\"key\":\"usernameLdapAttribute\",\"value\":\"Username LDAP attribute\"},{\"key\":\"selectEvictionMinute\",\"value\":\"Select eviction minute\"},{\"key\":\"idpAccountEmailVerification\",\"value\":\"IdP account email verification\"},{\"key\":\"deleteConfirmTitle_other\",\"value\":\"Delete groups?\"},{\"key\":\"profilesConfigTypes.jsonEditor\",\"value\":\"JSON editor\"},{\"key\":\"noUsersFoundError\",\"value\":\"No users found due to {{error}}\"},{\"key\":\"backchannelLogoutHelp\",\"value\":\"Does the external IDP support backchannel logout?\"},{\"key\":\"eventTypes.REMOVE_FEDERATED_IDENTITY_ERROR.description\",\"value\":\"Remove federated identity error\"},{\"key\":\"exportSamlKeyTitle\",\"value\":\"Export SAML Keys\"},{\"key\":\"eventTypes.EXECUTE_ACTIONS_ERROR.description\",\"value\":\"Execute actions error\"},{\"key\":\"SKIP\",\"value\":\"Skip\"},{\"key\":\"deleteCredentialsConfirm\",\"value\":\"Are you sure you want to delete these users credentials?\"},{\"key\":\"keysIntro\",\"value\":\"If \\\"Use JWKS URL switch\\\" is on, you need to fill a valid JWKS URL. After saving, admin can download keys from the JWKS URL or keys will be downloaded automatically by Keycloak server when an unknown KID is seen during client authentication.\"},{\"key\":\"logoutServiceArtifactBindingUrl\",\"value\":\"Logout Service ARTIFACT Binding URL\"},{\"key\":\"sessionsType.regularSSO\",\"value\":\"Regular SSO\"},{\"key\":\"contentSecurityPolicy\",\"value\":\"Content-Security-Policy\"},{\"key\":\"executorsHelpItem\",\"value\":\"Executors help item\"},{\"key\":\"hide\",\"value\":\"Hide\"},{\"key\":\"updatedCredentialMoveSuccess\",\"value\":\"User Credential configuration has been saved\"},{\"key\":\"deleteExecutorProfileConfirmTitle\",\"value\":\"Delete executor?\"},{\"key\":\"auth\",\"value\":\"Auth\"},{\"key\":\"eventTypes.INVALID_SIGNATURE.description\",\"value\":\"Invalid signature\"},{\"key\":\"download\",\"value\":\"Download\"},{\"key\":\"uuidLdapAttributeHelp\",\"value\":\"Name of the LDAP attribute, which is used as a unique object identifier (UUID) for objects in LDAP. For many LDAP server vendors, it is 'entryUUID'; however some are different. For example, for Active directory it should be 'objectGUID'. If your LDAP server does not support the notion of UUID, you can use any other attribute that is supposed to be unique among LDAP users in tree. For example 'uid' or 'entryDN'.\"},{\"key\":\"permissionSaveError\",\"value\":\"Could not update the permission due to {{error}}\"},{\"key\":\"optimizeLookupHelp\",\"value\":\"When signing SAML documents in REDIRECT binding for SP that is secured by Keycloak adapter, should the ID of the signing key be included in SAML protocol message in <Extensions> element? This optimizes validation of the signature as the validating party uses a single key instead of trying every known key for validation.\"},{\"key\":\"accessTokenError\",\"value\":\"Could not regenerate access token due to: {{error}}\"},{\"key\":\"joinGroups\",\"value\":\"Join Groups\"},{\"key\":\"scopePermissions.clients.configure-description\",\"value\":\"Reduced management permissions for administrator. Cannot set scope, template, or protocol mappers.\"},{\"key\":\"browserFlow\",\"value\":\"Browser Flow\"},{\"key\":\"organizationUsersLeft_other\",\"value\":\"{{count}} users left the organization\"},{\"key\":\"consents\",\"value\":\"Consents\"},{\"key\":\"mappingDeletedError\",\"value\":\"Could not delete mapping: '{{error}}'\"},{\"key\":\"minimumQuickLoginWaitSecondsHelp\",\"value\":\"How long to wait after a quick login failure.\"},{\"key\":\"deleteGrantsSuccess\",\"value\":\"Grants successfully revoked.\"},{\"key\":\"mapperTypeGroupLdapMapper\",\"value\":\"group-ldap-mapper\"},{\"key\":\"notBeforeTooltip\",\"value\":\"The admin URL should be set in the Settings tab first.\"},{\"key\":\"generatedUserInfoIsDisabled\",\"value\":\"Generated user info is disabled when no user is selected\"},{\"key\":\"createClientConditionError\",\"value\":\"Error creating condition: {{error}}\"},{\"key\":\"invalidateRotatedError\",\"value\":\"Could not remove rotated secret: {{error}}\"},{\"key\":\"initialAccessToken\",\"value\":\"Initial access token\"},{\"key\":\"applyToResourceType\",\"value\":\"Apply to Resource Type\"},{\"key\":\"selectRole.tooltip\",\"value\":\"Enter role in the textbox to the left, or click this button to browse and select the role you want.\"},{\"key\":\"validPostLogoutRedirectUri\",\"value\":\"Valid post logout redirect URIs\"},{\"key\":\"authnContextClassRefs\",\"value\":\"AuthnContext ClassRefs\"},{\"key\":\"cibaPolicy\",\"value\":\"CIBA Policy\"},{\"key\":\"importSkipped_other\",\"value\":\"{{count}} records skipped.\"},{\"key\":\"executeActionsHelp\",\"value\":\"Specifies independent timeout for execute actions.\"},{\"key\":\"composite\",\"value\":\"Composite\"},{\"key\":\"policyProvider.aggregate\",\"value\":\"Reuse existing policies to build more complex ones and keep your permissions even more decoupled from the policies that are evaluated during the processing of authorization requests.\"},{\"key\":\"advancedAttributeToRole\",\"value\":\"If the set of attributes exists and can be matched, grant the user the specified realm or client role.\"},{\"key\":\"userEventsSettings\",\"value\":\"User events settings\"},{\"key\":\"authorizationScopeDetails\",\"value\":\"Authorization scope details\"},{\"key\":\"passwordPoliciesHelp.notContainsUsername\",\"value\":\"The password cannot contains the username.\"},{\"key\":\"addExecutionTitle\",\"value\":\"Add an execution\"},{\"key\":\"effectiveMessageBundles\",\"value\":\"Effective message bundles\"},{\"key\":\"clientSecretSuccess\",\"value\":\"Client secret regenerated\"},{\"key\":\"linkIdentityProvider\",\"value\":\"Link identity provider\"},{\"key\":\"ecdsaGenerated\",\"value\":\"ecdsca-generated\"},{\"key\":\"excludeIssuerFromAuthenticationResponse\",\"value\":\"Exclude Issuer From Authentication Response\"},{\"key\":\"groupsHelp\",\"value\":\"Groups where the user has membership. To leave a group, click the cross button.\"},{\"key\":\"groupsPermissionsHint\",\"value\":\"Determines if fine grained permissions are enabled for managing this role.  Disabling will delete all current permissions that have been set up.\"},{\"key\":\"clientPoliciesTab\",\"value\":\"Client policies tab\"},{\"key\":\"ldapGroupsDn\",\"value\":\"LDAP groups DN\"},{\"key\":\"ldapFullNameAttributeHelp\",\"value\":\"Name of the LDAP attribute, which contains the fullName of the user. Usually it will be 'cn'.\"},{\"key\":\"missingFirstNameMessage\",\"value\":\"'{{0}}': Please specify first name.\"},{\"key\":\"key\",\"value\":\"Key\"},{\"key\":\"policyDeletedError\",\"value\":\"Could not remove the resource {{error}}\"},{\"key\":\"groupDeleted_other\",\"value\":\"Groups deleted\"},{\"key\":\"userAddedOrganization_one\",\"value\":\"Organization added to the user\"},{\"key\":\"loginActionTimeoutHelp\",\"value\":\"Max time a user has to complete login related actions like update password or configure totp. This is recommended to be relatively long, such as 5 minutes or more\"},{\"key\":\"leaveGroup_other\",\"value\":\"Leave groups?\"},{\"key\":\"userManagedAccessHelp\",\"value\":\"If enabled, users are allowed to manage their resources and permissions using the Account Management UI.\"},{\"key\":\"confirm\",\"value\":\"Confirm\"},{\"key\":\"policyType.totp\",\"value\":\"Time based\"},{\"key\":\"clientScopeSearch.protocol\",\"value\":\"Protocol\"},{\"key\":\"deleteProvider\",\"value\":\"Delete provider?\"},{\"key\":\"createAttributeSubTitle\",\"value\":\"Create a new attribute\"},{\"key\":\"eventTypes.CODE_TO_TOKEN_ERROR.name\",\"value\":\"Code to token error\"},{\"key\":\"organizationRemoveError\",\"value\":\"Could not remove user from organizations: {{error}}\"},{\"key\":\"emptyAuthorizationInstructions\",\"value\":\"If you want to create authorization scopes, please click the button below to create the authorization scope\"},{\"key\":\"privateRSAKeyHelp\",\"value\":\"Private RSA Key encoded in PEM format\"},{\"key\":\"requirements.REQUIRED\",\"value\":\"Required\"},{\"key\":\"resetPasswordBtn\",\"value\":\"Reset password\"},{\"key\":\"dateFrom\",\"value\":\"Date(from)\"},{\"key\":\"kcNumberUnFormat\",\"value\":\"Number UnFormat\"},{\"key\":\"permissionName\",\"value\":\"The name of this permission.\"},{\"key\":\"clientRegisterPolicyDeleteConfirmTitle\",\"value\":\"Delete client registration policy?\"},{\"key\":\"groupDetails\",\"value\":\"Group details\"},{\"key\":\"kid\",\"value\":\"Kid\"},{\"key\":\"