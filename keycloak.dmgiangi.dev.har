,\"value\":\"Could not create initial access token {{error}}\"},{\"key\":\"deleteConfirmExecutionMessage\",\"value\":\"Are you sure you want to permanently delete the execution \\\"<1>{{name}}</1>\\\".\"},{\"key\":\"connectionTimeoutHelp\",\"value\":\"LDAP connection timeout in milliseconds\"},{\"key\":\"repeat\",\"value\":\"Repeat\"},{\"key\":\"eventTypes.UPDATE_CREDENTIAL.description\",\"value\":\"Update credential\"},{\"key\":\"emptyUserOrganizations\",\"value\":\"No organizations\"},{\"key\":\"searchForProtocol\",\"value\":\"Search protocol mapper\"},{\"key\":\"eventTypes.CLIENT_INFO.name\",\"value\":\"Client info\"},{\"key\":\"eventTypes.UPDATE_TOTP_ERROR.name\",\"value\":\"Update totp error\"},{\"key\":\"webAuthnPolicyRpId\",\"value\":\"Relying party ID\"},{\"key\":\"expandRow\",\"value\":\"Expand row\"},{\"key\":\"supportJwtClaimInIntrospectionResponseHelp\",\"value\":\"If it is On, introspection requests which use the header 'Accept: application/jwt' will also contain a claim named \\\"jwt\\\" with the claims of the introspection result encoded as JWT access token.\"},{\"key\":\"invalidPasswordMinLowerCaseCharsMessage\",\"value\":\"Invalid password: must contain at least {0} lower case characters.\"},{\"key\":\"mapperAttributeName\",\"value\":\"Attribute Name\"},{\"key\":\"setPassword\",\"value\":\"Set password\"},{\"key\":\"eventTypes.IDENTITY_PROVIDER_RESPONSE_ERROR.description\",\"value\":\"Identity provider response error\"},{\"key\":\"createRole\",\"value\":\"Create role\"},{\"key\":\"enableServiceAccount\",\"value\":\"Enable service account roles\"},{\"key\":\"SSOSessionMaxRememberMe\",\"value\":\"SSO Session Max Remember Me\"},{\"key\":\"unlockError\",\"value\":\"Could not unlock user due to {{error}}\"},{\"key\":\"saveSuccess\",\"value\":\"User federation provider successfully saved\"},{\"key\":\"requestObjectEncryptionHelp\",\"value\":\"JWE algorithm, which client needs to use when sending OIDC request object specified by 'request' or 'request_uri' 