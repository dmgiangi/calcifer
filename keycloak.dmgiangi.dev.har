date consent error\"},{\"key\":\"overrideActionTokens\",\"value\":\"Override Action Tokens\"},{\"key\":\"addAssociatedRolesError\",\"value\":\"Could not associate roles {{error}}\"},{\"key\":\"removeUserText\",\"value\":\"Do you want to remove {{numSelected}} users?. These users will no longer have permissions of the role {{role}} and the associated roles of it.\"},{\"key\":\"removeImportedUsers\",\"value\":\"Remove imported users?\"},{\"key\":\"diagramView\",\"value\":\"Diagram view\"},{\"key\":\"anyClient\",\"value\":\"The condition is satisfied by any client on any event.\"},{\"key\":\"eventTypes.USER_DISABLED_BY_PERMANENT_LOCKOUT.name\",\"value\":\"User disabled by permanent lockout\"},{\"key\":\"deleteUser\",\"value\":\"Delete user\"},{\"key\":\"eventTypes.INTROSPECT_TOKEN_ERROR.description\",\"value\":\"Introspect token error\"},{\"key\":\"whoCanViewHelp\",\"value\":\"If enabled, users or administrators can view the attribute. Otherwise, users or administrators don't have access to the attribute.\"},{\"key\":\"includeClients\",\"value\":\"Include clients\"},{\"key\":\"updateCredentialUserLabelSuccess\",\"value\":\"The user label has been changed successfully.\"},{\"key\":\"credentialUserLabel\",\"value\":\"User Label\"},{\"key\":\"disableSuccess\",\"value\":\"Provider successfully disabled\"},{\"key\":\"attributes\",\"value\":\"Attributes\"},{\"key\":\"roleDeleteConfirmDialog\",\"value\":\"This action will permanently delete the role \\\"{{selectedRoleName}}\\\" and cannot be undone.\"},{\"key\":\"clientDelete\",\"value\":\"Delete {{clientId}} ?\"},{\"key\":\"updateCibaSuccess\",\"value\":\"CIBA policy successfully updated\"},{\"key\":\"replyToDisplayPlaceholder\",\"value\":\"Display name for \\\"reply to\\\" email address\"},{\"key\":\"eventTypes.INVALID_SIGNATURE.name\",\"value\":\"Invalid signature\"},{\"key\":\"selectMapperType\",\"value\":\"Select mapper type\"},{\"key\":\"members\",\"value\":\"Members\"},{\"key\":\"realmCertificateAliasHelp\",\"value\":\