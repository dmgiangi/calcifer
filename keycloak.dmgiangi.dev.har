ensHelp\",\"value\":\"Enable/disable if tokens must be stored after authenticating users.\"},{\"key\":\"addAssociatedRolesSuccess\",\"value\":\"Associated roles have been added\"},{\"key\":\"noSearchResultsInstructions\",\"value\":\"Click on the search bar above to search again\"},{\"key\":\"cibaBackhannelTokenDeliveryModes.poll\",\"value\":\"Poll\"},{\"key\":\"policies\",\"value\":\"Policies\"},{\"key\":\"backchannelLogoutSessionRequired\",\"value\":\"Backchannel logout session required\"},{\"key\":\"eventTypes.PUSHED_AUTHORIZATION_REQUEST_ERROR.name\",\"value\":\"Pushed authorization request error\"},{\"key\":\"editAttribute\",\"value\":\"Edit attribute\"},{\"key\":\"refreshTokenMaxReuse\",\"value\":\"Refresh Token Max Reuse\"},{\"key\":\"ldapErrorMissingClientId\",\"value\":\"Client ID needs to be provided in config when Realm Roles Mapping is not used.\"},{\"key\":\"cancelBtn\",\"value\":\"Cancel editing button\"},{\"key\":\"requiredAction\",\"value\":\"Required action\"},{\"key\":\"policyClientHelp\",\"value\":\"Specifies which client(s) are allowed by this policy.\"},{\"key\":\"algorithmNotSpecified\",\"value\":\"Algorithm not specified\"},{\"key\":\"connectionAndAuthenticationSettings\",\"value\":\"Connection and authentication settings\"},{\"key\":\"deleteConfirmUsers\",\"value\":\"Delete user?\"},{\"key\":\"eventTypes.TOKEN_EXCHANGE_ERROR.name\",\"value\":\"Token exchange error\"},{\"key\":\"maxTemporaryLockouts\",\"value\":\"Maximum temporary lockouts\"},{\"key\":\"mapperTypeHardcodedAttributeMapper\",\"value\":\"hardcoded-attribute-mapper\"},{\"key\":\"eventTypes.UPDATE_CREDENTIAL.name\",\"value\":\"Update credential\"},{\"key\":\"welcome\",\"value\":\"Welcome to\"},{\"key\":\"events\",\"value\":\"Events\"},{\"key\":\"validateConnectionUrl\",\"value\":\"You must enter a connection URL\"},{\"key\":\"cibaAuthRequestedUserHintHelp\",\"value\":\"The way of identifying the end-user for whom authentication is being requested. Currently only \\\"login_hint\\\" i