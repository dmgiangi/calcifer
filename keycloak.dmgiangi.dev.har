\",\"value\":\"All\"},{\"key\":\"keyAlias\",\"value\":\"Key alias\"},{\"key\":\"eventTypes.USER_INFO_REQUEST_ERROR.name\",\"value\":\"User info request error\"},{\"key\":\"removeUser\",\"value\":\"Remove users\"},{\"key\":\"userModelAttributeNameHelp\",\"value\":\"Name of the model attribute to be added when importing user from LDAP\"},{\"key\":\"permissions\",\"value\":\"Permissions\"},{\"key\":\"eventTypes.CODE_TO_TOKEN.description\",\"value\":\"Code to token\"},{\"key\":\"deleteClientPolicyConditionConfirm\",\"value\":\"This action will permanently delete {{condition}}. This cannot be undone.\"},{\"key\":\"attributeGroupHelp\",\"value\":\"Specifies the user profile group where this attribute will be added. This allows grouping various similar attributes together on different parts of the screen when creating or updating user.\"},{\"key\":\"mapperSaveError\",\"value\":\"Error saving mapper: {{error}}\"},{\"key\":\"mapperTypeHardcodedLdapGroupMapperHelp\",\"value\":\"Users imported from LDAP will be automatically added into this configured group.\"},{\"key\":\"selectRequestObjectEncryption\",\"value\":\"Select request object encryption\"},{\"key\":\"defaultACRValuesHelp\",\"value\":\"Default values to be used as voluntary ACR in case that there is no explicit ACR requested by 'claims' or 'acr_values' parameter in the OIDC request.\"},{\"key\":\"searchGroup\",\"value\":\"Search group\"},{\"key\":\"allowCreateHelp\",\"value\":\"Allow the external identity provider to create a new identifier to represent the principal.\"},{\"key\":\"includeInAccessTokenResponse.tooltip\",\"value\":\"Should the claim be added to the access token response? Should only be used for informative and non-sensitive data\"},{\"key\":\"clientAuthentications.client_secret_post\",\"value\":\"Client secret sent as post\"},{\"key\":\"valueError\",\"value\":\"A value must be provided.\"},{\"key\":\"authenticationAliasHelp\",\"value\":\"Name of the configuration\"},{\"key\":\"SSOSessionIdle\",\"value\":\"SSO Session Idle\"},{\"key\":\"connectionTimeout\",\"value\":\"Connection timeout\"},{\"key\":\"headerName\",\"value\":\"header name\"},{\"key\":\"mapperTypeUserAttributeLdapMapper\",\"value\":\"user-attribute-ldap-mapper\"},{\"key\":\"usersAdded_other\",\"value\":\"{{count}} users added to the group\"},{\"key\":\"socialProfileJSONFieldPath\",\"value\":\"Social Profile JSON Field Path\"},{\"key\":\"signatureKeyNameHelp\",\"value\":\"Signed SAML documents contain identification of signing key in KeyName element. For Keycloak / RH-SSO counterparty, use KEY_ID, for MS AD FS use CERT_SUBJECT, for others check and use NONE if no other option works.\"},{\"key\":\"decisionStrategies.UNANIMOUS\",\"value\":\"Unanimous\"},{\"key\":\"groupsPathHelp\",\"value\":\"Keycloak group path the LDAP groups are added to. For example if value '/Applications/App1' is used, then LDAP groups will be available in Keycloak under group 'App1', which is child of top level group 'Applications'. The default value is '/' so LDAP groups will be mapped to the Keycloak groups at the top level. The configured group path must already exist in the Keycloak when creating this mapper.\"},{\"key\":\"addPolicy\",\"value\":\"Add policy\"},{\"key\":\"tokenClaimName.label\",\"value\":\"Token Claim Name\"},{\"key\":\"extendToChildren\",\"value\":\"Extend to children\"},{\"key\":\"unmanagedAttributePolicy.DISABLED\",\"value\":\"Disabled\"},{\"key\":\"deleteClientPolicyProfileError\",\"value\":\"Could not delete profile from the policy: {{error}}\"},{\"key\":\"conditionsHelp\",\"value\":\"Conditions, which will be evaluated to determine if client policy should be applied during particular action or not.\"},{\"key\":\"emptyPoliciesInstructions\",\"value\":\"If you want to create a policy, please click the button below to create the policy.\"},{\"key\":\"logoUrl\",\"value\":\"Logo URL\"},{\"key\":\"loa-condition-level.tooltip\",\"value\":\"Level of authentication. This value should be always integer, which is 