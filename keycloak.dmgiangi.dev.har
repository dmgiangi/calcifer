naged\"},{\"key\":\"hideOrganizationLinkedIdps\",\"value\":\"Hide organization linked identity providers\"},{\"key\":\"forceNameIdFormat\",\"value\":\"Force name ID format\"},{\"key\":\"noMappersInstructions\",\"value\":\"There are currently no mappers for this identity provider.\"},{\"key\":\"userInfoSignedResponseAlgorithmHelp\",\"value\":\"JWA algorithm used for signed User Info Endpoint response. If set to 'unsigned', User Info Response won't be signed and will be returned in application/json format.\"},{\"key\":\"unmanagedAttributes\",\"value\":\"Unmanaged Attributes\"},{\"key\":\"createError\",\"value\":\"Could not create the identity provider: {{error}}\"},{\"key\":\"sendInvitation\",\"value\":\"Send invitation\"},{\"key\":\"policyGroupsHelp\",\"value\":\"Specifies which user(s) are allowed by this policy.\"},{\"key\":\"userRoleMappingUpdatedSuccess\",\"value\":\"User role mapping successfully updated\"},{\"key\":\"attributesDropdown\",\"value\":\"Attributes dropdown\"},{\"key\":\"invalidateSecret\",\"value\":\"Invalidate\"},{\"key\":\"readOnlySelection\",\"value\":\"Read only selection\"},{\"key\":\"copyOf\",\"value\":\"Copy of {{name}}\"},{\"key\":\"eventTypes.REMOVE_TOTP.description\",\"value\":\"Remove totp\"},{\"key\":\"evictionMinute\",\"value\":\"Eviction minute\"},{\"key\":\"nodeReRegistrationTimeoutHelp\",\"value\":\"Interval to specify max time for registered clients cluster nodes to re-register. If cluster node will not send re-registration request to Keycloak within this time, it will be unregistered from Keycloak\"},{\"key\":\"registrationEmailAsUsername\",\"value\":\"Email as username\"},{\"key\":\"mapperTypeMsadUserAccountControlManager\",\"value\":\"msad-user-account-control-mapper\"},{\"key\":\"authenticationExplain\",\"value\":\"Authentication is the area where you can configure and manage different credential types.\"},{\"key\":\"passwordPoliciesHelp.hashIterations\",\"value\":\"The number of times a password is hashed before storage or verification. Default: -1 in case argon2 is used as the hashing algorithm; 210,000 in case pbkdf2-sha512 is used as the hashing algorithm; 600,000 if the pbkdf2-sha256 algorithm is used as the hashing algorithm; 1,300,000 if the pbkdf2 algorithm is used as the hashing algorithm.\"},{\"key\":\"addProvider_other\",\"value\":\"Add {{provider}} providers\"},{\"key\":\"dynamicScopeFormatHelp\",\"value\":\"This is the regular expression that the system will use to extract the scope name and variable.\"},{\"key\":\"passSubjectHelp\",\"value\":\"During login phase, forward an optional login_hint query parameter to SAML AuthnRequest's Subject.\"},{\"key\":\"maxLifespan\",\"value\":\"Max lifespan\"},{\"key\":\"host-sending-registration-request-must-match.label\",\"value\":\"Host Sending Client Registration Request Must Match\"},{\"key\":\"profilesConfigType\",\"value\":\"Configure via:\"},{\"key\":\"linkedOrganization\",\"value\":\"Linked organization\"},{\"key\":\"enableHelp\",\"value\":\"Help is enabled\"},{\"key\":\"xRobotsTagHelp\",\"value\":\"Prevent pages from appearing in search engines <1>Learn more</1>\"},{\"key\":\"client-updater-source-roles.label\",\"value\":\"Updating entity role\"},{\"key\":\"resourceFile\",\"value\":\"Resource file\"},{\"key\":\"disableConfirmOrganizationTitle\",\"value\":\"Disable organization?\"},{\"key\":\"scopesSelect\",\"value\":\"Specifies that this permission must be applied to one or more scopes.\"},{\"key\":\"updatePermissionSuccess\",\"value\":\"Successfully updated the permission\"},{\"key\":\"referrerPolicy\",\"value\":\"Referrer Policy\"},{\"key\":\"flow.clients\",\"value\":\"Client authentication flow\"},{\"key\":\"permanentLockoutHelp\",\"value\":\"Configures whether a user is temporarily or permanently disabled after too many login failures. Permanent lockout can be configured to occur after a number of login failures or after a number of temporary lockouts.\"},{\"key\":\"startBySearchingAUser\",\"value\":\"Start by searching for users\"},{\"key\":\"times.days\",\"value\":\"Days\"},{\"key\":\"deleteConfirm_other\",\"value\":\"Are you sure you want to delete these groups.\"},{\"key\":\"trusted-hosts.label\",\"value\":\"Trusted Hosts\"},{\"key\":\"searchAttributes\",\"value\":\"Search attributes\"},{\"key\":\"userID\",\"value\":\"User ID\"},{\"key\":\"sync-ldap-roles-to-keycloak\",\"value\":\"Sync LDAP roles to Keycloak\"},{\"key\":\"eventTypes.FEDERATED_IDENTITY_LINK_ERROR.description\",\"value\":\"Federated identity link error\"},{\"key\":\"requiredRoles\",\"value\":\"Please add at least one role.\"},{\"key\":\"addLdapWizardTitle\",\"value\":\"Add LDAP user federation provider\"},{\"key\":\"wantAssertionsSignedHelp\",\"value\":\"Indicates whether this service provider expects a signed Assertion.\"},{\"key\":\"eventTypes.IDENTITY_PROVIDER_FIRST_LOGIN_ERROR.name\",\"value\":\"Identity provider first login error\"},{\"key\":\"credentialType\",\"value\":\"Type\"},{\"key\":\"httpPostBindingAuthnRequestHelp\",\"value\":\"Indicates whether the AuthnRequest must be sent using HTTP-POST binding. If false, HTTP-REDIRECT binding will be used.\"},{\"key\":\"organizationDetails\",\"value\":\"Organization details\"},{\"key\":\"secretRotated\",\"value\":\"Secret rotated\"},{\"key\":\"userCredentialsHelpTextLabel\",\"value\":\"User Credentials Help Text\"},{\"key\":\"organizationsMembersListError\",\"value\":\"Could not fetch organization members: {{error}}\"},{\"key\":\"clientDescriptionHelp\",\"value\":\"Specifies description of the client. For example 'My Client for TimeSheets'. Supports keys for localized values as well. For example: ${my_client_description}\"},{\"key\":\"realmNameTitle\",\"value\":\"{{name}} realm\"},{\"key\":\"artifactBindingUrlHelp\",\"value\":\"URL to send the HTTP ARTIFACT messages to. You can leave this blank if you are using a different binding. This value should be set when forcing ARTIFACT binding together with IdP initiated login.\"},{\"key\":\"userId\",\"value\":\"User ID\"},{\"key\":\"dedicatedScopeExplain\",\"value\":\"This is a client scope which includes the dedicated mappers and scope\"},{\"key\":\"noDirectUsers\",\"value\":\"No direct users\"},{\"key\":\"eventTypes.LOGIN.name\",\"value\":\"Login\"},{\"key\":\"uuidLdapAttribute\",\"value\":\"UUID LDAP attribute\"},{\"key\":\"clientAssertionAudience\",\"value\":\"Client assertion audience\"},{\"key\":\"clearFileExplain\",\"value\":\"Are you sure you want to clear this file?\"},{\"key\":\"syncRegistrationsHelp\",\"value\":\"Should newly created users be created within LDAP store? Priority effects which provider is chosen to sync the new user. This setting is effectively appplied only with WRITABLE edit mode.\"},{\"key\":\"emptyExecution\",\"value\":\"No steps\"},{\"key\":\"updateFirstLogin\",\"value\":\"Update first login\"},{\"key\":\"ldapAttributeHelp\",\"value\":\"Name of mapped attribute on LDAP object. For example 'cn', 'sn', 'mail', 'street', etc.\"},{\"key\":\"export\",\"value\":\"Export\"},{\"key\":\"assertionLifespan\",\"value\":\"Assertion Lifespan\"},{\"key\":\"claimFilterNameHelp\",\"value\":\"Name of the essential claim\"},{\"key\":\"rolesScope\",\"value\":\"If there is no role scope mapping defined, each user is permitted to use this client scope. If there are role scope mappings defined, the user must be a member of at least one of the roles.\"},{\"key\":\"flowUsedByDescription\",\"value\":\"This flow is used by the following {{value}}\"},{\"key\":\"flows\",\"value\":\"Flows\"},{\"key\":\"removeImportedUsersSuccess\",\"value\":\"Imported users have been removed.\"},{\"key\":\"error-invalid-uri\",\"value\":\"'{{0}}' is invalid URL.\"},{\"key\":\"sessionsType.directGrant\",\"value\":\"Direct grant\"},{\"key\":\"validateSignature\",\"value\":\"Validate Signatures\"},{\"key\":\"exportSuccess\",\"value\":\"Realm successfully exported.\"},{\"key\":\"validateBindDn\",\"value\":\"You must enter the DN of the LDAP admin\"},{\"key\":\"inputTypeCols\",\"value\":\"Input cols\"},{\"