ntRolesConditionTooltip\",\"value\":\"Client roles, which will be checked during this condition evaluation. Condition evaluates to true if client has at least one client role with the name as the client roles specified in the configuration.\"},{\"key\":\"showPasswordDataValue\",\"value\":\"Value\"},{\"key\":\"help\",\"value\":\"Help\"},{\"key\":\"parRequestUriLifespan\",\"value\":\"Lifetime of the Request URI for Pushed Authorization Request\"},{\"key\":\"policyProvider.client\",\"value\":\"Define conditions for your permissions where a set of one or more clients is permitted to access an object.\"},{\"key\":\"validatePasswordPolicy\",\"value\":\"Validate password policy\"},{\"key\":\"webAuthnPolicyFormHelp\",\"value\":\"Policy for WebAuthn authentication. This one will be used by 'WebAuthn Register' required action and 'WebAuthn Authenticator' authenticator. Typical usage is, when WebAuthn will be used for the two-factor authentication.\"},{\"key\":\"createNewMapper\",\"value\":\"Create new mapper\"},{\"key\":\"syncModeOverrideHelp\",\"value\":\"Overrides the default sync mode of the IDP for this mapper. Values are: 'legacy' to keep the behaviour before this option was introduced, 'import' to only import the user once during first login of the user with this identity provider, 'force' to always update the user during every login with this identity provider and 'inherit' to use the sync mode defined in the identity provider for this mapper.\"},{\"key\":\"strictTransportSecurityHelp\",\"value\":\"The Strict-Transport-Security HTTP header tells browsers to always use HTTPS. Once a browser sees this header, it will only visit the site over HTTPS for the time specified (1 year) at max-age, including the subdomains. <1>Learn more</1>\"},{\"key\":\"dropNonexistingGroupsDuringSync\",\"value\":\"Drop non-existing groups during sync\"},{\"key\":\"cibaExpiresIn\",\"value\":\"Expires In\"},{\"key\":\"resetPasswordConfirmText\",\"value\":\"Are you sure you want to reset the password for the user {{username}}?\"},{\"key\":\"create\",\"value\":\"Create\"},{\"key\":\"notBeforeSetToNow\",\"value\":\"Not Before set for client\"},{\"key\":\"emptyConditions\",\"value\":\"No conditions configured\"},{\"key\":\"userSession.modelNote.tooltip\",\"value\":\"Name of stored user session note within the UserSessionModel.note map.\"},{\"key\":\"filterByRoles\",\"value\":\"Filter by realm roles\"},{\"key\":\"clientRegisterPolicyDeleteError\",\"value\":\"Could not delete client registration policy: '{{error}}'\"},{\"key\":\"send\",\"value\":\"Send\"},{\"key\":\"backchannelLogoutUrlIsInvalid\",\"value\":\"Backchannel logout URL is not a valid URL\"},{\"key\":\"eventTypes.INVALID_SIGNATURE_ERROR.description\",\"value\":\"Invalid signature error\"},{\"key\":\"idpUnlinkSuccess\",\"value\":\"The provider link has been removed\"},{\"key\":\"missingPasswordMessage\",\"value\":\"'{{0}}': Please specify password.\"},{\"key\":\"providerType\",\"value\":\"Provider Type\"},{\"key\":\"clientSessionIdleHelp\",\"value\":\"Time a client session is allowed to be idle before it expires. Tokens are invalidated when a client session is expired. The option does not affect the global user SSO session. If not set, it uses the standard SSO Session Idle value.\"},{\"key\":\"passwordPoliciesHelp.hashAlgorithm\",\"value\":\"Applies a hashing algorithm to passwords, so they are not stored in clear text.\"},{\"key\":\"emailInvalid\",\"value\":\"You must enter a valid email.\"},{\"key\":\"clientSecretHelp\",\"value\":\"The client secret registered with the identity provider. This field is able to obtain its value from vault, use ${vault.ID} format.\"},{\"key\":\"webAuthnPolicyExtraOriginsHelp\",\"value\":\"The list of extra origins for non-web applications.\"},{\"key\":\"accountTheme\",\"value\":\"Account theme\"},{\"key\":\"emptyExecutors\",\"value\":\"No executors configured\"},{\"key\":\"titleAuthentication\",\"value\":\"Authentication\"},{\"key\":\"anyResource\",\"value\":\"Any resource\"},{\"key\":\"clientSignature\",\"value\":\"Client signature required\"},{\"key\":\"persistent\",\"value\":\"Persistent\"},{\"key\":\"disableConfirm\",\"value\":\"Are you sure you want to disable '{{name}}'\"},{\"key\":\"flowName\",\"value\":\"Flow name\"},{\"key\":\"userInfoResponseEncryptionContentEncryptionAlgorithm\",\"value\":\"User info response encryption content encryption algorithm\"},{\"key\":\"passLoginHint\",\"value\":\"Pass login_hint\"},{\"key\":\"openIdConnectCompatibilityModesHelp\",\"value\":\"This section is used to configure settings for backward compatibility with older OpenID Connect / OAuth 2 adaptors. It's useful especially if your client uses older version of Keycloak / RH-SSO adapter.\"},{\"key\":\"eventTypes.CLIENT_UPDATE.name\",\"value\":\"Client update\"},{\"key\":\"notRepeat\",\"value\":\"Not repeat\"},{\"key\":\"userFedDeleteConfirmTitle\",\"value\":\"Delete user federation provider?\"},{\"key\":\"envelopeFrom\",\"value\":\"Envelope from\"},{\"key\":\"updateCibaError\",\"value\":\"Could not update CIBA policy: {{error}}\"},{\"key\":\"rolesPermissionsHint\",\"value\":\"Determines if fine grained permissions are enabled for managing this role.  Disabling will delete all current permissions that have been set up.\"},{\"key\":\"oAuthDPoP\",\"value\":\"OAuth 2.0 DPoP Bound Access Tokens Enabled\"},{\"key\":\"addTranslationsModalSubTitleDescription\",\"value\":\"You are able to translate the \\\"Display description\\\" based on your locale or preferred languages. In addition, you are also able to create or edit the \\\"Display description\\\" translations in the\"},{\"key\":\"credentialsList\",\"value\":\"Credentials List\"},{\"key\":\"internationalizationHelp\",\"value\":\"If enabled, you can choose which locales you support for this realm and which locale is the default.\"},{\"key\":\"managePriorityOrder\",\"value\":\"Manage priority order\"},{\"key\":\"emptyMappers\",\"value\":\"No mappers\"},{\"key\":\"clientsList\",\"value\":\"Clients list\"},{\"key\":\"eventTypes.CLIENT_UPDATE_ERROR.description\",\"value\":\"Client update error\"},{\"key\":\"defaultRoles\",\"value\":\"Default roles\"},{\"key\":\"sendClientIdOnLogoutHelp\",\"value\":\"If the 'client_id' parameter should be sent in logout requests.\"},{\"key\":\"samlSignatureKeyNameHelp\",\"value\":\"Signed SAML documents contain identification of signing key in KeyName element. For Keycloak / RH-SSO counter-party, use KEY_ID, for MS AD FS use CERT_SUBJECT, for others check and use NONE if no other option works.\"},{\"key\":\"clientScopeTypes.default\",\"value\":\"Default\"},{\"key\":\"addressClaim.country.tooltip\",\"value\":\"Name of User Attribute, which will be used to map to 'country' subclaim inside 'address' token claim. Defaults to 'country' .\"},{\"key\":\"requiredUserActions\",\"value\":\"Required user actions\"},{\"key\":\"userInitiatedActionLifespanHelp\",\"value\":\"Maximum time before an action permit sent by a user (such as a forgot password e-mail) is expired. This value is recommended to be short because it's expected that the user would react to self-created action quickly.\"},{\"key\":\"passwordPolicyHintsEnabledHelp\",\"value\":\"Applicable just for writable MSAD. If on, then updating password of MSAD user will use LDAP_SERVER_POLICY_HINTS_OID extension, which means that advanced MSAD password policies like 'password history' or 'minimal password age' will be applied. This extension works just for MSAD 2008 R2 or newer.\"},{\"key\":\"eventTypes.IMPERSONATE.name\",\"value\":\"Impersonate\"},{\"key\":\"columnDisplayDescription\",\"value\":\"Display description\"},{\"key\":\"flowUsedBy\",\"value\":\"Use of this flow\"},{\"key\":\"client-updater-trusted-hosts.label\",\"value\":\"Trusted hosts\"},{\"key\":\"updateExecutorSuccess\",\"value\":\"Executor updated successfully\"},{\"key\":\"eventTypes.CODE_TO_TOKEN_ERROR.description\",\"value\":\"Code to token error\"},{\"key\":\"revocationDescription\",\"value\":\"This is a way to revoke all active sessions and access tokens. Not before means you can revoke any tokens issued before the date.\"},{\"key\":\"backchannelLogout\",\"value\":\"Backchannel logout\"},{\"key\":\"addressClaim.street.label\",\"value\":\"User Attribute Name for Street\"},{\"key\":\"applyToResourceTypeFlag\",\"value\":\"Apply to resource type\"},{\"key\":\"testError\",\"value\":\"Error when trying to connect to LDAP: '{{error}}'\"},{\"key\":\"clientRedirectURIsFragmentError\",\"value\":\"Redirect URIs must not contain an URI fragment\"},{\"key\":\"realmRolePrefix\",\"value\":\"Realm role prefix\"},{\"key\":\"invalidJsonClientPoliciesError\",\"value\":\"Unable to save client policies, the provided information is not valid JSON: {{error}}\"},{\"key\":\"expireTimeHelp\",\"value\":\"Defines the time after which the policy MUST NOT be granted. Only granted if current date/time is before or equal to this value.\"},{\"key\":\"editIdPMapper\",\"value\":\"Edit Identity Provider Mapper\"},{\"key\":\"eventTypes.VERIFY_PROFILE_ERROR.name\",\"value\":\"Verify profile error\"},{\"key\":\"signAssertionsHelp\",\"value\":\"Should assertions inside SAML documents be signed? This setting is not needed if document is already being signed.\"},{\"key\":\"authnContextClassRefsHelp\",\"value\":\"Ordered list of requested AuthnContext ClassRefs.\"},{\"key\":\"ldapAttributeNameHelp\",\"value\":\"Name of the LDAP attribute, which will be added to the new user during registration\"},{\"key\":\"ldapErrorMissingGroupsPathGroup\",\"value\":\"Groups path group does not exist - please create the group on specified path first\"},{\"key\":\"scopePermissions.groups.manage-description\",\"value\":\"Policies that decide if an administrator can manage this group\"},{\"key\":\"testClusterFail\",\"value\":\"Failed verified availability for: {{failedNodes}}. Fix or unregister failed cluster nodes and try again\"},{\"key\":\"queryExtensions\",\"value\":\"Query Supported Extensions\"},{\"key\":\"signingKeysConfig\",\