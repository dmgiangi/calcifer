lue\":\"Could not create the identity provider: {{error}}\"},{\"key\":\"samlKeysExportError\",\"value\":\"Could not export keys due to: {{error}}\"},{\"key\":\"clientRootURLInvalid\",\"value\":\"Root URL is not a valid URL\"},{\"key\":\"addTranslationsModalSubTitle\",\"value\":\"You are able to translate the \\\"Display name\\\" based on your locale or preferred languages. In addition, you are also able to create or edit the \\\"Display name\\\" translations in the\"},{\"key\":\"dependentPermission\",\"value\":\"Dependent permission\"},{\"key\":\"unsyncedSelection\",\"value\":\"Unsynced selection\"},{\"key\":\"policiesConfigType\",\"value\":\"Configure via:\"},{\"key\":\"parentClientScope\",\"value\":\"Parent client scope\"},{\"key\":\"ldapFilter\",\"value\":\"LDAP filter\"},{\"key\":\"webAuthnPolicyRpEntityNameHelp\",\"value\":\"Human-readable server name as WebAuthn Relying Party\"},{\"key\":\"partialExportHeaderText\",\"value\":\"Partial export allows you to export realm configuration, and other associated resources into a json file.\"},{\"key\":\"clientScopes\",\"value\":\"Client scopes\"},{\"key\":\"eventTypes.SEND_RESET_PASSWORD_ERROR.description\",\"value\":\"Send reset password error\"},{\"key\":\"showLess\",\"value\":\"Show less\"},{\"key\":\"defaultGroups\",\"value\":\"Default groups\"},{\"key\":\"flow.browser\",\"value\":\"Browser flow\"},{\"key\":\"addressClaim.street.tooltip\",\"value\":\"Name of User Attribute, which will be used to map to 'street_address' subclaim inside 'address' token claim. Defaults to 'street' .\"},{\"key\":\"createAttributeError\",\"value\":\"Error! User Profile configuration has not been saved {{error}}.\"},{\"key\":\"httpPostBindingResponseHelp\",\"value\":\"Indicates whether to respond to requests using HTTP-POST binding. If false, HTTP-REDIRECT binding will be used.\"},{\"key\":\"clientAuthorization\",\"value\":\"Authorization\"},{\"key\":\"selectTheme\",\"value\":\"Select theme\"},{\"key\":\"duplicatedJwksSettings\",\"value\